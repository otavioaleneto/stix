# GODSend CMS - Configuracao de Ambiente
# Copie este arquivo para .env e preencha os valores

# ============ BANCO DE DADOS ============
# Dialeto: mysql ou postgres
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=godsend
DB_USER=godsend_user
DB_PASS=SUA_SENHA_AQUI

# Ou use uma URL de conexao (substitui as variaveis acima)
# DATABASE_URL=mysql://usuario:senha@localhost:3306/godsend

# ============ SERVIDOR ============
# Porta do servidor (padrao: 5000)
PORT=5000

# Segredo para sessoes (use uma string aleatoria longa)
SESSION_SECRET=mude-para-uma-string-aleatoria-longa-aqui

# ============ API ============
# true = API aberta sem autenticacao (para testes)
# false = requer API key validada pelo WordPress
API_OPEN_ACCESS=false

# ============ HTTPS ============
# true = forcar HTTPS (quando o site usa SSL)
# false = usar HTTP (padrao)
FORCE_HTTPS=false

# ============ ADMIN INICIAL ============
# Credenciais do admin criado na primeira instalacao
ADMIN_USER=admin
ADMIN_PASS=admin123
ADMIN_EMAIL=admin@seudominio.com
