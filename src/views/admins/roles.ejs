<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Cargos e Permissões</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <a href="/admins" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
            Admins
          </a>
          <span class="text-gray-600">|</span>
          <h1 class="text-lg font-semibold text-white">Cargos e Permissões</h1>
        </div>
        <button type="button" onclick="document.getElementById('newRoleModal').classList.remove('hidden')" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Cargo
        </button>
      </div>

      <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-900/50 border border-red-500/50 p-4">
        <p class="text-sm text-red-300"><%= error %></p>
      </div>
      <% } %>

      <% if (success) { %>
      <div class="mb-4 rounded-lg bg-green-900/50 border border-green-500/50 p-4">
        <p class="text-sm text-green-300"><%= success %></p>
      </div>
      <% } %>

      <div class="space-y-4">
        <% roles.forEach(role => { %>
        <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-700">
            <div class="flex items-center gap-3">
              <span class="text-base font-semibold text-white"><%= role.name %></span>
              <% if (role.is_system) { %>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-500/10 text-blue-400">Sistema</span>
              <% } %>
            </div>
            <div class="flex items-center gap-2">
              <button type="button" onclick="openEditModal(<%= role.id %>)" class="text-sm text-brand-400 hover:text-brand-300">Editar</button>
              <% if (!role.is_system) { %>
              <form action="/admins/roles/<%= role.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Excluir este cargo?')">
                <button type="submit" class="text-sm text-red-400 hover:text-red-300 ml-2">Excluir</button>
              </form>
              <% } %>
            </div>
          </div>
          <div class="px-6 py-4">
            <% if (role.description) { %>
            <p class="text-sm text-gray-400 mb-3"><%= role.description %></p>
            <% } %>
            <div class="flex flex-wrap gap-2">
              <% const rolePerms = role.permissions || []; %>
              <% availablePermissions.forEach(perm => { %>
              <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-medium <%= rolePerms.includes(perm.key) ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-gray-700 text-gray-500 border border-gray-600' %>">
                <% if (rolePerms.includes(perm.key)) { %>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <% } else { %>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                <% } %>
                <%= perm.label %>
              </span>
              <% }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <div id="newRoleModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60">
        <div class="bg-gray-800 border border-gray-700 rounded-xl w-full max-w-lg mx-4 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-white">Novo Cargo</h3>
            <button type="button" onclick="document.getElementById('newRoleModal').classList.add('hidden')" class="text-gray-400 hover:text-white">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <form action="/admins/roles" method="POST">
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Cargo</label>
                <input type="text" name="name" required placeholder="ex: moderador"
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Descrição</label>
                <input type="text" name="description" placeholder="Descrição do cargo"
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">Permissões</label>
                <div class="space-y-2">
                  <% availablePermissions.forEach(perm => { %>
                  <label class="flex items-start gap-3 p-2 rounded-lg hover:bg-gray-700/50 cursor-pointer <%= perm.parent ? 'ml-6 border-l-2 border-gray-600' : '' %>">
                    <input type="checkbox" name="permissions" value="<%= perm.key %>"
                      class="mt-0.5 rounded bg-gray-700 border-gray-600 text-brand-600 focus:ring-brand-500"
                      <% if (perm.parent) { %>data-parent="<%= perm.parent %>"<% } %>>
                    <div>
                      <span class="text-sm font-medium text-white"><%= perm.label %></span>
                      <p class="text-xs text-gray-400"><%= perm.description %></p>
                    </div>
                  </label>
                  <% }) %>
                </div>
              </div>
            </div>
            <div class="mt-6 flex items-center gap-3">
              <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">Criar Cargo</button>
              <button type="button" onclick="document.getElementById('newRoleModal').classList.add('hidden')" class="rounded-lg bg-gray-700 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Cancelar</button>
            </div>
          </form>
        </div>
      </div>

      <% roles.forEach(role => { %>
      <div id="editModal-<%= role.id %>" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60">
        <div class="bg-gray-800 border border-gray-700 rounded-xl w-full max-w-lg mx-4 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-white">Editar Cargo: <%= role.name %></h3>
            <button type="button" onclick="document.getElementById('editModal-<%= role.id %>').classList.add('hidden')" class="text-gray-400 hover:text-white">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <form action="/admins/roles/<%= role.id %>" method="POST">
            <div class="space-y-4">
              <% if (!role.is_system) { %>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Cargo</label>
                <input type="text" name="name" value="<%= role.name %>" required
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
              </div>
              <% } %>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Descrição</label>
                <input type="text" name="description" value="<%= role.description || '' %>"
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">Permissões</label>
                <div class="space-y-2">
                  <% const editPerms = role.permissions || []; %>
                  <% availablePermissions.forEach(perm => { %>
                  <label class="flex items-start gap-3 p-2 rounded-lg hover:bg-gray-700/50 cursor-pointer <%= perm.parent ? 'ml-6 border-l-2 border-gray-600' : '' %>">
                    <input type="checkbox" name="permissions" value="<%= perm.key %>" <%= editPerms.includes(perm.key) ? 'checked' : '' %>
                      class="mt-0.5 rounded bg-gray-700 border-gray-600 text-brand-600 focus:ring-brand-500"
                      <% if (perm.parent) { %>data-parent="<%= perm.parent %>"<% } %>>
                    <div>
                      <span class="text-sm font-medium text-white"><%= perm.label %></span>
                      <p class="text-xs text-gray-400"><%= perm.description %></p>
                    </div>
                  </label>
                  <% }) %>
                </div>
              </div>
            </div>
            <div class="mt-6 flex items-center gap-3">
              <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">Salvar</button>
              <button type="button" onclick="document.getElementById('editModal-<%= role.id %>').classList.add('hidden')" class="rounded-lg bg-gray-700 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Cancelar</button>
            </div>
          </form>
        </div>
      </div>
      <% }) %>

      <script>
      function openEditModal(id) {
        document.getElementById('editModal-' + id).classList.remove('hidden');
      }

      document.addEventListener('change', function(e) {
        if (e.target.type === 'checkbox' && e.target.name === 'permissions') {
          const form = e.target.closest('form');
          if (!form) return;
          const val = e.target.value;
          const parentAttr = e.target.dataset.parent;

          if (!parentAttr && e.target.checked === false) {
            form.querySelectorAll('input[data-parent="' + val + '"]').forEach(function(child) {
              child.checked = false;
            });
          }

          if (parentAttr && e.target.checked) {
            const parentCb = form.querySelector('input[name="permissions"][value="' + parentAttr + '"]');
            if (parentCb && !parentCb.checked) {
              parentCb.checked = true;
            }
          }
        }
      });
      </script>

    </main>
  </div>
</body>
</html>
