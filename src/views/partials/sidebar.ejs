<style>
  .sidebar-full { width: 16rem; }
  .sidebar-collapsed { width: 4.5rem; }
  .sidebar-collapsed .sidebar-label { display: none; }
  .sidebar-collapsed .sidebar-header { justify-content: center; padding-left: 0; padding-right: 0; }
  .sidebar-collapsed nav a,
  .sidebar-collapsed nav button { justify-content: center; padding-left: 0.75rem; padding-right: 0.75rem; }
  .sidebar-collapsed .sidebar-collapse-icon { display: none; }
  .sidebar-collapsed .sidebar-expand-icon { display: block; }
  .sidebar-full .sidebar-expand-icon { display: none; }
  .sidebar-full .sidebar-collapse-icon { display: block; }
  .sidebar-collapsed nav a { gap: 0; }
  .sidebar-collapsed nav button { gap: 0; }
  .sidebar-collapsed .sidebar-submenu { display: none; }
  .sidebar-collapsed .sidebar-submenu-container { position: relative; }
  .sidebar-collapsed #sidebar-collapse-btn .sidebar-label { display: none; }
  .submenu-chevron-games.rotated,
  .submenu-chevron-blog.rotated,
  .submenu-chevron-sobre.rotated,
  .submenu-chevron-dl.rotated { transform: rotate(180deg); }
  .sidebar-submenu-toggle { text-align: left; }
  .sidebar-nav::-webkit-scrollbar { width: 4px; }
  .sidebar-nav::-webkit-scrollbar-track { background: transparent; }
  .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
  .sidebar-nav::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
</style>
<script>
(function() {
  function applySidebarState() {
    var sidebar = document.getElementById('sidebar');
    if (!sidebar) return;
    var collapsed = localStorage.getItem('sidebar_collapsed') === 'true';
    if (collapsed) {
      sidebar.classList.remove('sidebar-full');
      sidebar.classList.add('sidebar-collapsed');
    } else {
      sidebar.classList.remove('sidebar-collapsed');
      sidebar.classList.add('sidebar-full');
    }
    document.querySelectorAll('.sidebar-content-area').forEach(function(el) {
      if (collapsed) {
        el.classList.remove('lg:pl-64');
        el.classList.add('lg:pl-[4.5rem]');
      } else {
        el.classList.remove('lg:pl-[4.5rem]');
        el.classList.add('lg:pl-64');
      }
    });
    document.querySelectorAll('.sidebar-navbar').forEach(function(el) {
      if (collapsed) {
        el.classList.remove('lg:pl-64');
        el.classList.add('lg:pl-[4.5rem]');
      } else {
        el.classList.remove('lg:pl-[4.5rem]');
        el.classList.add('lg:pl-64');
      }
    });
  }

  function initSidebarToggle() {
    var btn = document.getElementById('sidebar-collapse-btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var collapsed = localStorage.getItem('sidebar_collapsed') === 'true';
      localStorage.setItem('sidebar_collapsed', collapsed ? 'false' : 'true');
      applySidebarState();
    });
  }

  applySidebarState();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { applySidebarState(); initSidebarToggle(); });
  } else {
    initSidebarToggle();
  }

  window.applySidebarState = applySidebarState;
  window.initSidebarToggle = initSidebarToggle;
  window.toggleSubmenu = function(name) {
    var submenu = document.getElementById('submenu-' + name);
    var chevron = document.querySelector('.submenu-chevron-' + name);
    if (submenu) {
      submenu.classList.toggle('hidden');
    }
    if (chevron) {
      chevron.classList.toggle('rotated');
    }
  };
  window.toggleSobreSubmenu = function() { window.toggleSubmenu('sobre'); };
})();
</script>
