<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Conquistas Xbox</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-white">Conquistas Xbox</h1>
          <p class="mt-1 text-sm text-gray-400"><%= total %> conquista(s) registrada(s) de jogos Xbox 360</p>
        </div>
        <form method="GET" action="/social/game-achievements" class="flex items-center gap-2">
          <select name="game_id" class="rounded-lg bg-gray-800 border border-gray-600 px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Todos os Jogos</option>
            <% games.forEach(function(g) { %>
              <option value="<%= g.id %>" <%= selectedGameId == g.id ? 'selected' : '' %>><%= g.title %></option>
            <% }); %>
          </select>
          <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Filtrar</button>
        </form>
      </div>

      <% if (achievements.length === 0) { %>
        <div class="rounded-xl bg-gray-800 border border-gray-700 p-8 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-500 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          <p class="text-gray-400 text-sm">Nenhuma conquista Xbox registrada ainda.</p>
          <p class="text-gray-500 text-xs mt-1">As conquistas aparecem aqui quando os jogadores as colhem pela WebUI.</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          <% achievements.forEach(function(ach) { %>
            <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden hover:border-gray-600 transition-colors">
              <div class="flex items-start gap-3 p-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-lg overflow-hidden bg-gray-700">
                  <% if (ach.image_url) { %>
                    <img src="<%= ach.image_url %>" alt="" class="w-full h-full object-cover" onerror="this.onerror=null;this.parentElement.innerHTML='<div class=&quot;w-full h-full flex items-center justify-center text-2xl&quot;>🏆</div>'">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center text-2xl">🏆</div>
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-white truncate"><%= ach.name %></h3>
                  <p class="text-xs text-gray-400 mt-0.5 line-clamp-2"><%= ach.description || '' %></p>
                  <% if (ach.gamerscore > 0) { %>
                    <span class="inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full bg-yellow-900/30 text-yellow-400 text-xs font-medium">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      <%= ach.gamerscore %>G
                    </span>
                  <% } %>
                </div>
              </div>
              <div class="border-t border-gray-700 px-4 py-2 flex items-center justify-between">
                <% if (ach.game) { %>
                  <span class="text-xs text-gray-500 truncate"><%= ach.game.title %></span>
                <% } else { %>
                  <span class="text-xs text-gray-600">Title ID: <%= ach.title_id %></span>
                <% } %>
                <span class="text-xs text-gray-600">ID: <%= ach.achievement_id %></span>
              </div>
            </div>
          <% }); %>
        </div>

        <% if (totalPages > 1) { %>
          <div class="mt-6 flex items-center justify-center gap-2">
            <% if (currentPage > 1) { %>
              <a href="/social/game-achievements?page=<%= currentPage - 1 %><%= selectedGameId ? '&game_id=' + selectedGameId : '' %>" class="rounded-lg bg-gray-700 px-3 py-1.5 text-sm text-gray-300 hover:bg-gray-600 transition-colors">&larr; Anterior</a>
            <% } %>
            <span class="text-sm text-gray-400">P&aacute;gina <%= currentPage %> de <%= totalPages %></span>
            <% if (currentPage < totalPages) { %>
              <a href="/social/game-achievements?page=<%= currentPage + 1 %><%= selectedGameId ? '&game_id=' + selectedGameId : '' %>" class="rounded-lg bg-gray-700 px-3 py-1.5 text-sm text-gray-300 hover:bg-gray-600 transition-colors">Pr&oacute;xima &rarr;</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </main>
  </div>
</body>
</html>
