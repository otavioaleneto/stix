<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= profile.display_name || profile.username %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6">
        <a href="/social/profiles" class="text-sm text-gray-400 hover:text-white transition-colors">&larr; Voltar para Perfis</a>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 p-6 mb-6">
        <div class="flex items-start gap-4">
          <% if (profile.avatar_url) { %>
          <img src="<%= profile.avatar_url %>" class="w-16 h-16 rounded-full" alt="" onerror="this.style.display='none'">
          <% } else { %>
          <div class="w-16 h-16 rounded-full bg-gray-600 flex items-center justify-center text-2xl text-white"><%= ((profile.display_name || profile.username || '?')[0] || '?').toUpperCase() %></div>
          <% } %>
          <div class="flex-1">
            <h1 class="text-xl font-bold text-white"><%= profile.display_name || profile.username %></h1>
            <p class="text-sm text-gray-400"><%= profile.email || '' %></p>
            <% if (profile.level_name) { %>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-yellow-500/20 text-yellow-400 mt-1"><%= profile.level_name %></span>
            <% } %>
            <% if (profile.bio) { %>
            <p class="text-sm text-gray-300 mt-2"><%= profile.bio %></p>
            <% } %>
          </div>
          <a href="/social/profiles/<%= profile.id %>/edit" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 transition-colors">Editar</a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mt-6 pt-4 border-t border-gray-700">
          <div class="text-center">
            <div class="text-xl font-bold text-white"><%= profile.total_downloads || 0 %></div>
            <div class="text-xs text-gray-400">Downloads</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white"><%= profile.achievements_count || 0 %></div>
            <div class="text-xs text-gray-400">Conquistas</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white"><%= profile.games_completed || 0 %></div>
            <div class="text-xs text-gray-400">Completos</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white"><%= friendCount || 0 %></div>
            <div class="text-xs text-gray-400">Amigos</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white"><%= Math.floor((profile.total_playtime_minutes || 0) / 60) %>h</div>
            <div class="text-xs text-gray-400">Playtime</div>
          </div>
        </div>
      </div>

      <div class="mb-4 flex gap-2">
        <button class="tab-btn rounded-lg px-4 py-2 text-sm font-medium bg-brand-600 text-white" data-tab="achievements" onclick="switchTab(this)">Conquistas (<%= profile.achievements ? profile.achievements.length : 0 %>)</button>
        <button class="tab-btn rounded-lg px-4 py-2 text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600" data-tab="rooms" onclick="switchTab(this)">Salas (<%= profile.createdRooms ? profile.createdRooms.length : 0 %>)</button>
        <button class="tab-btn rounded-lg px-4 py-2 text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600" data-tab="comments" onclick="switchTab(this)">Comentários (<%= profile.comments ? profile.comments.length : 0 %>)</button>
        <button class="tab-btn rounded-lg px-4 py-2 text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600" data-tab="award" onclick="switchTab(this)">Conceder</button>
      </div>

      <div id="tab-achievements" class="tab-content">
        <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
          <% if (!profile.achievements || profile.achievements.length === 0) { %>
          <div class="px-4 py-8 text-center text-gray-400 text-sm">Nenhuma conquista ainda.</div>
          <% } else { %>
          <div class="divide-y divide-gray-700">
            <% profile.achievements.forEach(function(ach) { %>
            <div class="px-4 py-3 flex items-center gap-3">
              <span class="text-2xl"><%= ach.icon || '🏆' %></span>
              <div class="flex-1">
                <div class="text-sm font-medium text-white"><%= ach.achievement_name %></div>
                <div class="text-xs text-gray-400"><%= ach.achievement_description || '' %></div>
              </div>
              <div class="text-xs text-gray-500"><%= ach.unlocked_at ? new Date(ach.unlocked_at).toLocaleDateString('pt-BR') : '' %></div>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <div id="tab-rooms" class="tab-content hidden">
        <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
          <% if (!profile.createdRooms || profile.createdRooms.length === 0) { %>
          <div class="px-4 py-8 text-center text-gray-400 text-sm">Nenhuma sala criada.</div>
          <% } else { %>
          <div class="divide-y divide-gray-700">
            <% profile.createdRooms.forEach(function(room) { %>
            <div class="px-4 py-3 flex items-center justify-between">
              <div>
                <div class="text-sm font-medium text-white"><%= room.title %></div>
                <div class="text-xs text-gray-400"><%= room.game_title || (room.game ? room.game.title : '') %></div>
              </div>
              <% var sc = { scheduled: 'bg-blue-500/20 text-blue-400', active: 'bg-green-500/20 text-green-400', finished: 'bg-gray-500/20 text-gray-400', cancelled: 'bg-red-500/20 text-red-400' }; %>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= sc[room.status] || 'bg-gray-500/20 text-gray-400' %>"><%= room.status %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <div id="tab-comments" class="tab-content hidden">
        <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
          <% if (!profile.comments || profile.comments.length === 0) { %>
          <div class="px-4 py-8 text-center text-gray-400 text-sm">Nenhum comentário.</div>
          <% } else { %>
          <div class="divide-y divide-gray-700">
            <% profile.comments.forEach(function(c) { %>
            <div class="px-4 py-3">
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs text-gray-400"><%= c.game ? c.game.title : 'Jogo #' + c.game_id %></span>
                <span class="text-xs text-gray-500"><%= new Date(c.createdAt).toLocaleDateString('pt-BR') %></span>
              </div>
              <p class="text-sm text-gray-300"><%= c.comment_text %></p>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <div id="tab-award" class="tab-content hidden">
        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <h3 class="text-lg font-medium text-white mb-4">Conceder Conquista a <%= profile.display_name || profile.username %></h3>
          <% var userAchKeys = (profile.achievements || []).map(function(a) { return a.achievement_key; }); %>
          <% var available = allAchievements.filter(function(a) { return userAchKeys.indexOf(a.key) === -1; }); %>
          <% if (available.length === 0) { %>
          <p class="text-sm text-gray-400">Este usuario ja possui todas as conquistas ativas.</p>
          <% } else { %>
          <div class="space-y-2">
            <% available.forEach(function(ach) { %>
            <div class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-gray-700/50">
              <div class="flex items-center gap-2">
                <span class="text-xl"><%= ach.icon || '🏆' %></span>
                <div>
                  <div class="text-sm text-white"><%= ach.name %></div>
                  <div class="text-xs text-gray-400"><%= ach.description || '' %></div>
                </div>
              </div>
              <button onclick="awardAch('<%= ach.key %>', this)" class="rounded-lg bg-brand-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-500 transition-colors">Conceder</button>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

<script>
function switchTab(btn) {
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.remove('bg-brand-600', 'text-white');
    b.classList.add('bg-gray-700', 'text-gray-300');
  });
  btn.classList.remove('bg-gray-700', 'text-gray-300');
  btn.classList.add('bg-brand-600', 'text-white');
  document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.add('hidden'); });
  document.getElementById('tab-' + btn.getAttribute('data-tab')).classList.remove('hidden');
}

function awardAch(key, btn) {
  btn.disabled = true;
  btn.textContent = 'Concedendo...';
  fetch('/social/achievements/award', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ user_profile_id: <%= profile.id %>, achievement_key: key })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      btn.textContent = 'Concedida!';
      btn.classList.remove('bg-brand-600');
      btn.classList.add('bg-green-600');
    } else {
      btn.textContent = data.error || 'Erro';
      btn.classList.remove('bg-brand-600');
      btn.classList.add('bg-red-600');
    }
  })
  .catch(function(err) {
    btn.textContent = 'Erro';
    btn.classList.remove('bg-brand-600');
    btn.classList.add('bg-red-600');
  });
}
</script>
    </main>
  </div>
</body>
</html>
