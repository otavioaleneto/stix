<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Perfis</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-white">Perfis de Usuarios</h1>
          <p class="mt-1 text-sm text-gray-400"><%= totalProfiles %> perfil(is)</p>
        </div>
        <form action="/social/profiles" method="GET" class="flex gap-2">
          <input type="text" name="search" value="<%= search %>" placeholder="Buscar usuario..." class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 w-48">
          <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Buscar</button>
        </form>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Usuario</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden sm:table-cell">Nivel</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Downloads</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Conquistas</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden lg:table-cell">Ultimo Acesso</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Acoes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (profiles.length === 0) { %>
            <tr>
              <td colspan="6" class="px-4 py-8 text-center text-gray-400 text-sm">Nenhum perfil encontrado.</td>
            </tr>
            <% } else { %>
            <% profiles.forEach(function(p) { %>
            <tr class="hover:bg-gray-700/50 transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <% if (p.avatar_url) { %>
                  <img src="<%= p.avatar_url %>" class="w-8 h-8 rounded-full" alt="" onerror="this.style.display='none'">
                  <% } else { %>
                  <div class="w-8 h-8 rounded-full bg-gray-600 flex items-center justify-center text-sm text-white"><%= ((p.display_name || p.username || '?')[0] || '?').toUpperCase() %></div>
                  <% } %>
                  <div>
                    <div class="text-sm font-medium text-white"><%= p.display_name || p.username %></div>
                    <div class="text-xs text-gray-400"><%= p.email || '' %></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <% if (p.level_name) { %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-yellow-500/20 text-yellow-400"><%= p.level_name %></span>
                <% } else { %>
                <span class="text-xs text-gray-500">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-gray-300"><%= p.total_downloads || 0 %></span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-gray-300"><%= p.achievements_count || 0 %></span>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-sm text-gray-400"><%= p.last_seen ? new Date(p.last_seen).toLocaleDateString('pt-BR') : '-' %></span>
              </td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <a href="/social/profiles/<%= p.id %>" class="rounded-lg bg-blue-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-blue-500 transition-colors">Ver</a>
                  <a href="/social/profiles/<%= p.id %>/edit" class="rounded-lg bg-gray-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-gray-500 transition-colors">Editar</a>
                </div>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <nav class="mt-6 flex items-center justify-center gap-2">
        <% for (var p = 1; p <= totalPages; p++) { %>
        <a href="/social/profiles?page=<%= p %>&search=<%= search %>"
          class="rounded-lg px-3 py-2 text-sm font-medium transition-colors <%= p === currentPage ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
          <%= p %>
        </a>
        <% } %>
      </nav>
      <% } %>
    </main>
  </div>
</body>
</html>
