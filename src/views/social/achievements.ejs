<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Conquistas Stix</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-white">Conquistas Stix</h1>
          <p class="mt-1 text-sm text-gray-400"><%= achievements.length %> conquista(s) cadastrada(s)</p>
        </div>
        <a href="/social/achievements/new" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">+ Nova Conquista</a>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider w-12">Icone</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Nome</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden sm:table-cell">Chave</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Categoria</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Auto</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden lg:table-cell">Usuarios</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Acoes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (achievements.length === 0) { %>
            <tr>
              <td colspan="8" class="px-4 py-8 text-center text-gray-400 text-sm">Nenhuma conquista cadastrada.</td>
            </tr>
            <% } else { %>
            <% achievements.forEach(function(ach) { %>
            <tr class="hover:bg-gray-700/50 transition-colors">
              <td class="px-4 py-3">
                <span class="text-2xl"><%= ach.icon || '🏆' %></span>
              </td>
              <td class="px-4 py-3">
                <div class="text-sm font-medium text-white"><%= ach.name %></div>
                <div class="text-xs text-gray-400"><%= ach.description || '' %></div>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <code class="text-xs bg-gray-700 px-1.5 py-0.5 rounded text-gray-300"><%= ach.key %></code>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% var catColors = { download: 'bg-blue-500/20 text-blue-400', social: 'bg-purple-500/20 text-purple-400', membership: 'bg-yellow-500/20 text-yellow-400', special: 'bg-green-500/20 text-green-400' }; %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= catColors[ach.category] || catColors.special %>"><%= ach.category %></span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% if (ach.auto_rule) { %>
                <span class="text-xs text-green-400"><%= ach.auto_rule.type %><%= ach.auto_rule.threshold ? ' >= ' + ach.auto_rule.threshold : '' %><%= ach.auto_rule.level ? ': ' + ach.auto_rule.level : '' %></span>
                <% } else { %>
                <span class="text-xs text-gray-500">Manual</span>
                <% } %>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-sm text-gray-300"><%= awardedCounts[ach.key] || 0 %></span>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= ach.active ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>">
                  <%= ach.active ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <a href="/social/achievements/<%= ach.id %>/edit" class="rounded-lg bg-blue-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-blue-500 transition-colors">Editar</a>
                  <button onclick="deleteAch(<%= ach.id %>)" class="rounded-lg bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition-colors">Excluir</button>
                </div>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="mt-8 rounded-xl bg-gray-800 border border-gray-700 p-6">
        <h3 class="text-lg font-medium text-white mb-4">Conceder Conquista Manualmente</h3>
        <form id="award-form" class="flex flex-col sm:flex-row gap-3">
          <input type="number" id="award-user-id" placeholder="ID do Perfil" required class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white placeholder-gray-400 w-40">
          <select id="award-key" required class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white flex-1">
            <option value="">Selecione a conquista...</option>
            <% achievements.forEach(function(ach) { %>
            <option value="<%= ach.key %>"><%= ach.icon %> <%= ach.name %></option>
            <% }) %>
          </select>
          <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Conceder</button>
        </form>
        <p id="award-result" class="mt-2 text-sm hidden"></p>
      </div>

<script>
function deleteAch(id) {
  if (!confirm('Tem certeza que deseja excluir esta conquista?')) return;
  fetch('/social/achievements/' + id + '/delete', { method: 'POST', headers: { 'Accept': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) { if (data.success) location.reload(); else alert('Erro: ' + (data.error || 'Falha')); })
    .catch(function(err) { alert('Erro: ' + err.message); });
}

document.getElementById('award-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var userId = document.getElementById('award-user-id').value;
  var key = document.getElementById('award-key').value;
  var result = document.getElementById('award-result');
  if (!userId || !key) return;

  fetch('/social/achievements/award', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ user_profile_id: parseInt(userId), achievement_key: key })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    result.classList.remove('hidden');
    if (data.success) {
      result.className = 'mt-2 text-sm text-green-400';
      result.textContent = 'Conquista concedida com sucesso!';
    } else {
      result.className = 'mt-2 text-sm text-red-400';
      result.textContent = 'Erro: ' + (data.error || 'Falha');
    }
  })
  .catch(function(err) {
    result.classList.remove('hidden');
    result.className = 'mt-2 text-sm text-red-400';
    result.textContent = 'Erro: ' + err.message;
  });
});
</script>
    </main>
  </div>
</body>
</html>
