<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Editar Perfil</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6">
        <a href="/social/profiles/<%= profile.id %>" class="text-sm text-gray-400 hover:text-white transition-colors">&larr; Voltar para Perfil</a>
        <h1 class="text-2xl font-bold text-white mt-2">Editar Perfil: <%= profile.display_name || profile.username %></h1>
      </div>

      <form action="/social/profiles/<%= profile.id %>" method="POST" class="max-w-2xl">
        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Username</label>
            <p class="text-sm text-gray-400"><%= profile.username %> (WP ID: <%= profile.wp_user_id %>)</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nome de Exibicao</label>
            <input type="text" name="display_name" value="<%= profile.display_name || '' %>" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Bio</label>
            <textarea name="bio" rows="3" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white"><%= profile.bio || '' %></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nivel (Membership)</label>
            <input type="text" name="level_name" value="<%= profile.level_name || '' %>" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white" placeholder="ex: Gold, VIP, Platina">
          </div>
        </div>

        <div class="mt-6 flex gap-3">
          <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Salvar</button>
          <a href="/social/profiles/<%= profile.id %>" class="rounded-lg bg-gray-700 px-6 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Cancelar</a>
        </div>
      </form>
    </main>
  </div>
</body>
</html>
