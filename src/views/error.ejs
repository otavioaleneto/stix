<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full">
  <div class="flex min-h-full items-center justify-center py-12 px-4">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-gray-400"><%= title %></h1>
      <p class="mt-4 text-lg text-gray-300"><%= message %></p>
      <a href="/dashboard" class="mt-6 inline-block rounded-lg bg-green-600 px-6 py-3 text-sm font-semibold text-white hover:bg-green-500 transition-colors">Voltar ao Dashboard</a>
    </div>
  </div>
</body>
</html>
