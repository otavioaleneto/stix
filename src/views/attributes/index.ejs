                </div>
                <button type="button" onclick="toggleEdit(<%= attr.id %>)" class="text-gray-400 hover:text-white transition-colors" title="Editar">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                </button>
                <form method="POST" action="/attributes/<%= attr.id %>/delete" class="inline" onsubmit="return confirm('Remover este atributo?')">
                  <button type="submit" class="text-red-400 hover:text-red-300 transition-colors" title="Remover">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </form>
              </div>
              <form method="POST" action="/attributes/<%= attr.id %>/update" class="attr-edit hidden flex-1 flex items-center gap-2">
                <input type="number" name="sort_order" value="<%= attr.sort_order %>" class="w-14 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white text-center focus:ring-2 focus:ring-brand-500">
                <input type="text" name="value" value="<%= attr.value %>" class="w-24 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500">
                <input type="text" name="label" value="<%= attr.label %>" class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500">
                <button type="submit" class="rounded bg-brand-600 px-2 py-1.5 text-xs font-medium text-white hover:bg-brand-500">Salvar</button>
                <button type="button" onclick="toggleEdit(<%= attr.id %>)" class="text-gray-400 hover:text-white text-xs">Cancelar</button>
              </form>
            </div>
            <% }) %>
          </div>

          <div class="attr-pagination flex items-center justify-center gap-1 mb-4"></div>

          <form method="POST" action="/attributes" class="flex items-center gap-2 rounded-lg bg-gray-700/30 border border-dashed border-gray-600 p-3">
            <input type="hidden" name="category" value="platform">
            <input type="number" name="sort_order" value="0" class="w-14 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white text-center focus:ring-2 focus:ring-brand-500" placeholder="#">
            <input type="text" name="label" required class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500" placeholder="Nome exibido" oninput="autoKey(this)">
            <input type="hidden" name="value" value="">
            <button type="submit" class="rounded bg-brand-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-500">Adicionar</button>
          </form>
        </div>

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6 lg:col-span-2" data-card="category">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-medium text-white">Categorias</h3>
            <span class="text-xs text-gray-400"><%= categories.length %> item(s)</span>
          </div>

          <div class="space-y-2 mb-4 attr-list" data-items-per-page="15">
            <% categories.forEach(function(attr, idx) { %>
            <div class="attr-item flex items-center gap-3 rounded-lg bg-gray-700/50 border border-gray-600 p-3" id="attr-<%= attr.id %>" data-index="<%= idx %>">
              <div class="attr-display flex-1 flex items-center gap-3">
                <span class="text-xs text-gray-400 font-mono w-8 text-center"><%= attr.sort_order %></span>
                <div class="flex-1">
                  <span class="text-sm font-medium text-white"><%= attr.label %></span>
                  <span class="text-xs text-gray-400 ml-2">(<%= attr.value %>)</span>
                </div>
                <button type="button" onclick="toggleEdit(<%= attr.id %>)" class="text-gray-400 hover:text-white transition-colors" title="Editar">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                </button>
                <form method="POST" action="/attributes/<%= attr.id %>/delete" class="inline" onsubmit="return confirm('Remover este atributo?')">
                  <button type="submit" class="text-red-400 hover:text-red-300 transition-colors" title="Remover">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </form>
              </div>
              <form method="POST" action="/attributes/<%= attr.id %>/update" class="attr-edit hidden flex-1 flex items-center gap-2">
                <input type="number" name="sort_order" value="<%= attr.sort_order %>" class="w-14 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white text-center focus:ring-2 focus:ring-brand-500">
                <input type="text" name="value" value="<%= attr.value %>" class="w-24 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500">
                <input type="text" name="label" value="<%= attr.label %>" class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500">
                <button type="submit" class="rounded bg-brand-600 px-2 py-1.5 text-xs font-medium text-white hover:bg-brand-500">Salvar</button>
                <button type="button" onclick="toggleEdit(<%= attr.id %>)" class="text-gray-400 hover:text-white text-xs">Cancelar</button>
              </form>
            </div>
            <% }) %>
          </div>

          <div class="attr-pagination flex items-center justify-center gap-1 mb-4"></div>

          <form method="POST" action="/attributes" class="flex items-center gap-2 rounded-lg bg-gray-700/30 border border-dashed border-gray-600 p-3">
            <input type="hidden" name="category" value="category">
            <input type="number" name="sort_order" value="0" class="w-14 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white text-center focus:ring-2 focus:ring-brand-500" placeholder="#">
            <input type="text" name="label" required class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-2 py-1.5 text-xs text-white focus:ring-2 focus:ring-brand-500" placeholder="Nome exibido" oninput="autoKey(this)">
            <input type="hidden" name="value" value="">
            <button type="submit" class="rounded bg-brand-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-500">Adicionar</button>
          </form>
        </div>

      </div>

    </main>
  </div>
  <script>
  function toggleEdit(id) {
    var row = document.getElementById('attr-' + id);
    var display = row.querySelector('.attr-display');
    var edit = row.querySelector('.attr-edit');
    display.classList.toggle('hidden');
    edit.classList.toggle('hidden');
  }

  function autoKey(input) {
    var form = input.closest('form');
    var hiddenValue = form.querySelector('input[name="value"]');
    if (hiddenValue) {
      hiddenValue.value = input.value
        .trim()
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');
    }
  }

  function initPagination() {
    var lists = document.querySelectorAll('.attr-list');
    lists.forEach(function(list) {
      var items = list.querySelectorAll('.attr-item');
      var perPage = parseInt(list.getAttribute('data-items-per-page')) || 15;
      var totalItems = items.length;
      var totalPages = Math.ceil(totalItems / perPage);

      if (totalPages <= 1) {
        items.forEach(function(item) { item.style.display = ''; });
        return;
      }

      var currentPage = 1;
      var paginationContainer = list.parentElement.querySelector('.attr-pagination');

      function renderPage(page) {
        currentPage = page;
        var start = (page - 1) * perPage;
        var end = start + perPage;

        items.forEach(function(item, idx) {
          item.style.display = (idx >= start && idx < end) ? '' : 'none';
        });

        var html = '';
        if (currentPage > 1) {
          html += '<button onclick="goPage(this,' + (currentPage - 1) + ')" class="rounded-lg px-2 py-1 text-xs font-medium bg-gray-700 text-gray-300 hover:text-white border border-gray-600">&laquo;</button>';
        }

        var startPage = Math.max(1, currentPage - 2);
        var endPage = Math.min(totalPages, currentPage + 2);

        for (var i = startPage; i <= endPage; i++) {
          if (i === currentPage) {
            html += '<button class="rounded-lg px-2.5 py-1 text-xs font-medium bg-brand-600 text-white">' + i + '</button>';
          } else {
            html += '<button onclick="goPage(this,' + i + ')" class="rounded-lg px-2.5 py-1 text-xs font-medium bg-gray-700 text-gray-300 hover:text-white border border-gray-600">' + i + '</button>';
          }
        }

        if (currentPage < totalPages) {
          html += '<button onclick="goPage(this,' + (currentPage + 1) + ')" class="rounded-lg px-2 py-1 text-xs font-medium bg-gray-700 text-gray-300 hover:text-white border border-gray-600">&raquo;</button>';
        }

        html += '<span class="text-xs text-gray-500 ml-2">' + currentPage + '/' + totalPages + '</span>';
        paginationContainer.innerHTML = html;
      }

      list.setAttribute('data-render-page', '');
      list._renderPage = renderPage;
      renderPage(1);
    });
  }

  function goPage(btn, page) {
    var card = btn.closest('[data-card]');
    var list = card.querySelector('.attr-list');
    if (list && list._renderPage) {
      list._renderPage(page);
    }
  }

  initPagination();
  </script>
</body>
</html>
