<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Consoles</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-white">Consoles</h1>
          <p class="mt-1 text-sm text-gray-400"><%= totalConsoles %> console(s) registrado(s)</p>
        </div>
        <form action="/consoles" method="GET" class="flex gap-2">
          <input type="hidden" name="limit" value="<%= limit %>">
          <input type="text" name="search" value="<%= search %>" placeholder="Buscar Console ID..." class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 w-48">
          <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Buscar</button>
        </form>
      </div>

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-400">Por página:</span>
          <% [15, 30, 50].forEach(function(val) { %>
          <a href="/consoles?search=<%= search %>&limit=<%= val %>&page=1"
            class="rounded-lg px-3 py-1.5 text-sm font-medium transition-colors <%= val === limit ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
            <%= val %>
          </a>
          <% }) %>
        </div>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Console ID</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden sm:table-cell">Downloads Hoje</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Total Downloads</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden lg:table-cell">Primeiro Acesso</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Ultimo Acesso</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (consoles.length === 0) { %>
            <tr>
              <td colspan="7" class="px-4 py-8 text-center text-gray-400 text-sm">Nenhum console registrado ainda.</td>
            </tr>
            <% } else { %>
            <% consoles.forEach(function(c) { %>
            <tr class="hover:bg-gray-700/50 transition-colors" id="console-row-<%= c.id %>">
              <td class="px-4 py-3">
                <span class="text-sm font-mono text-white"><%= c.console_id %></span>
              </td>
              <td class="px-4 py-3">
                <span id="status-badge-<%= c.id %>" class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= c.banned ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400' %>">
                  <%= c.banned ? 'Banido' : 'Ativo' %>
                </span>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= c.downloads_today > 0 ? 'bg-yellow-500/20 text-yellow-400' : 'bg-gray-500/20 text-gray-400' %>">
                  <%= c.downloads_today %>
                </span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-gray-300"><%= c.total_downloads %></span>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-sm text-gray-400"><%= c.first_seen ? new Date(c.first_seen).toLocaleDateString('pt-BR') : 'N/A' %></span>
              </td>
              <td class="px-4 py-3">
                <span class="text-sm text-gray-400"><%= c.last_seen ? new Date(c.last_seen).toLocaleDateString('pt-BR') : 'N/A' %></span>
              </td>
              <td class="px-4 py-3">
                <% if (c.banned) { %>
                <button onclick="toggleBan(<%= c.id %>, 'unban')" class="rounded-lg bg-green-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-green-500 transition-colors">Desbanir</button>
                <% } else { %>
                <button onclick="toggleBan(<%= c.id %>, 'ban')" class="rounded-lg bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition-colors">Banir</button>
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <nav class="mt-6 flex items-center justify-center gap-2">
        <% for (let p = 1; p <= totalPages; p++) { %>
        <a href="/consoles?page=<%= p %>&search=<%= search %>&limit=<%= limit %>"
          class="rounded-lg px-3 py-2 text-sm font-medium transition-colors <%= p === currentPage ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
          <%= p %>
        </a>
        <% } %>
      </nav>
      <% } %>

<script>
  function toggleBan(id, action) {
    var msg = action === 'ban' ? 'Tem certeza que deseja banir este console?' : 'Tem certeza que deseja desbanir este console?';
    if (!confirm(msg)) return;

    fetch('/consoles/' + id + '/' + action, {
      method: 'POST',
      headers: { 'Accept': 'application/json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var badge = document.getElementById('status-badge-' + id);
        var row = document.getElementById('console-row-' + id);
        var btn = row.querySelector('td:last-child button');

        if (data.banned) {
          badge.className = 'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-500/20 text-red-400';
          badge.textContent = 'Banido';
          btn.className = 'rounded-lg bg-green-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-green-500 transition-colors';
          btn.textContent = 'Desbanir';
          btn.setAttribute('onclick', "toggleBan(" + id + ", 'unban')");
        } else {
          badge.className = 'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-500/20 text-green-400';
          badge.textContent = 'Ativo';
          btn.className = 'rounded-lg bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition-colors';
          btn.textContent = 'Banir';
          btn.setAttribute('onclick', "toggleBan(" + id + ", 'ban')");
        }
      }
    })
    .catch(function(err) {
      alert('Erro ao alterar status: ' + err.message);
    });
  }
  </script>
    </main>
  </div>
</body>
</html>
