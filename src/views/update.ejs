<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Atualizar Sistema</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">
      <div class="max-w-2xl mx-auto">
        <h1 class="text-2xl font-bold text-white mb-6">Atualizar Sistema</h1>

        <% if (updateSuccess) { %>
        <div class="rounded-xl bg-green-500/10 border border-green-500/20 p-4 mb-6">
          <div class="flex items-center gap-3">
            <svg class="h-6 w-6 text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div>
              <p class="text-green-400 font-medium">Atualizado com sucesso!</p>
              <p class="text-green-300/70 text-sm mt-1">O banco de dados foi atualizado para a versao <%= currentVersion %>.</p>
            </div>
          </div>
        </div>
        <% } %>

        <% if (updateError) { %>
        <div class="rounded-xl bg-red-500/10 border border-red-500/20 p-4 mb-6">
          <div class="flex items-center gap-3">
            <svg class="h-6 w-6 text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
            <div>
              <p class="text-red-400 font-medium">Erro na atualizacao</p>
              <p class="text-red-300/70 text-sm mt-1"><%= updateError %></p>
            </div>
          </div>
        </div>
        <% } %>

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <div class="grid grid-cols-2 gap-4 text-sm mb-6">
            <div>
              <p class="text-gray-400">Versao dos Arquivos</p>
              <p class="text-white text-lg font-semibold"><%= currentVersion %></p>
            </div>
            <div>
              <p class="text-gray-400">Versao do Banco de Dados</p>
              <p class="text-white text-lg font-semibold"><%= dbVersion %></p>
            </div>
          </div>

          <% if (needsUpdate) { %>
          <div class="rounded-lg bg-yellow-500/10 border border-yellow-500/20 p-4 mb-6">
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-yellow-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
              <div>
                <p class="text-yellow-400 font-medium">Atualizacao necessaria</p>
                <p class="text-yellow-300/70 text-sm mt-1">Os arquivos do sistema foram atualizados para a versao <%= currentVersion %>, mas o banco de dados ainda esta na versao <%= dbVersion %>. Clique no botao abaixo para atualizar o banco de dados.</p>
              </div>
            </div>
          </div>

          <form action="/update/run" method="POST">
            <button type="submit" class="w-full rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
              Atualizar Banco de Dados
            </button>
          </form>
          <% } else { %>
          <div class="rounded-lg bg-green-500/10 border border-green-500/20 p-4">
            <div class="flex items-center gap-3">
              <svg class="h-5 w-5 text-green-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="text-green-400 font-medium">Sistema atualizado</p>
            </div>
            <p class="text-green-300/70 text-sm mt-2 ml-8">O banco de dados esta na versao mais recente.</p>
          </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
