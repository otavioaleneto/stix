<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Acessos</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Controle de Acessos</h1>
          <p class="text-sm text-gray-400 mt-1">Configure quais niveis podem acessar a ferramenta e o limite de downloads diarios.</p>
        </div>
      </div>

      <% if (success) { %>
      <div class="mb-6 rounded-xl bg-green-500/10 border border-green-500/20 px-4 py-3">
        <p class="text-sm text-green-400">Configuracoes salvas com sucesso!</p>
      </div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2">
          <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-700">
              <h2 class="text-lg font-semibold text-white">Niveis Configurados</h2>
              <p class="text-sm text-gray-400 mt-1">Niveis de acesso e limites de downloads por dia</p>
            </div>

            <% if (levels.length === 0) { %>
            <div class="px-6 py-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <h3 class="mt-4 text-sm font-semibold text-white">Nenhum nivel configurado</h3>
              <p class="mt-2 text-sm text-gray-400">Adicione niveis de acesso usando o formulario ao lado.</p>
            </div>
            <% } else { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-800/50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Nivel</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Nome</th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Usuarios</th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Acesso</th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Downloads/Dia</th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Acoes</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                  <% levels.forEach(function(level) { %>
                  <tr class="hover:bg-gray-700/30">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="inline-flex items-center rounded-full bg-purple-500/10 px-2.5 py-0.5 text-xs font-medium text-purple-400">
                        Lv.<%= level.level_id %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-white font-medium"><%= level.name %></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                      <span class="inline-flex items-center gap-1 text-xs text-blue-400">
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                        <%= userCountByLevel[level.level_id] || 0 %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                      <% if (level.allowed) { %>
                      <span class="inline-flex items-center gap-1 text-xs text-green-400">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span>
                        Permitido
                      </span>
                      <% } else { %>
                      <span class="inline-flex items-center gap-1 text-xs text-red-400">
                        <span class="h-1.5 w-1.5 rounded-full bg-red-400"></span>
                        Bloqueado
                      </span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                      <span class="text-sm font-semibold text-white"><%= level.daily_limit %></span>
                      <span class="text-xs text-gray-400"> / dia</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                      <div class="inline-flex items-center gap-2">
                        <button type="button" onclick="editLevel(<%= level.level_id %>, '<%= level.name.replace(/'/g, "\\'") %>', <%= level.allowed %>, <%= level.daily_limit %>)" class="text-blue-400 hover:text-blue-300 transition-colors" title="Editar">
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                        </button>
                        <form method="POST" action="/access/delete/<%= level.level_id %>" class="inline" onsubmit="return confirm('Remover nivel <%= level.level_id %>?')">
                          <button type="submit" class="text-red-400 hover:text-red-300 transition-colors" title="Remover">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
          </div>
        </div>

        <div>
          <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-700">
              <h2 class="text-lg font-semibold text-white">Adicionar / Editar Nivel</h2>
            </div>
            <form method="POST" action="/access/add" class="p-6 space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Nivel (ID)</label>
                <% if (wpLevels.length > 0) { %>
                <select name="level_id" id="level-select" class="w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white focus:ring-2 focus:ring-brand-500">
                  <option value="">Selecionar nivel...</option>
                  <% wpLevels.forEach(function(wl) { %>
                  <option value="<%= wl.level_id %>" data-name="<%= wl.name %>">Lv.<%= wl.level_id %> - <%= wl.name %></option>
                  <% }) %>
                  <option value="custom">Personalizado...</option>
                </select>
                <input type="number" name="level_id_custom" id="level-custom-input" min="1" placeholder="ID do nivel"
                  class="hidden mt-2 w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500">
                <% } else { %>
                <input type="number" name="level_id" min="1" required placeholder="Ex: 1, 2, 3..."
                  class="w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500">
                <% } %>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Nome do Nivel</label>
                <input type="text" name="name" id="level-name" required placeholder="Ex: Gratis, Gold, Diamante..."
                  class="w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Acesso Permitido</label>
                <select name="allowed" class="w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white focus:ring-2 focus:ring-brand-500">
                  <option value="true">Sim - Pode acessar</option>
                  <option value="false">Nao - Bloqueado</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Downloads por Dia</label>
                <input type="number" name="daily_limit" min="0" value="1" required placeholder="Ex: 1, 5, 20..."
                  class="w-full rounded-lg border-0 bg-gray-700 px-4 py-2.5 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500">
                <p class="text-xs text-gray-500 mt-1">0 = sem limite</p>
              </div>
              <button type="submit" class="w-full rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
                Salvar Nivel
              </button>
            </form>
          </div>

          <% if (levels.length > 0) { %>
          <div class="mt-4 rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-700">
              <h2 class="text-sm font-semibold text-white">Resumo</h2>
            </div>
            <div class="p-6 space-y-3">
              <% levels.forEach(function(level) { %>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="h-2 w-2 rounded-full <%= level.allowed ? 'bg-green-400' : 'bg-red-400' %>"></span>
                  <span class="text-sm text-gray-300">Lv.<%= level.level_id %> - <%= level.name %></span>
                </div>
                <span class="text-sm font-medium text-white"><%= level.daily_limit === 0 ? 'Ilimitado' : level.daily_limit + '/dia' %></span>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>
      </div>


<script>
(function() {
  var sel = document.getElementById('level-select');
  var customInput = document.getElementById('level-custom-input');
  var nameInput = document.getElementById('level-name');
  if (sel) {
    sel.addEventListener('change', function() {
      if (this.value === 'custom') {
        customInput.classList.remove('hidden');
        customInput.required = true;
        nameInput.value = '';
      } else {
        customInput.classList.add('hidden');
        customInput.required = false;
        var opt = this.options[this.selectedIndex];
        if (opt && opt.dataset.name) {
          nameInput.value = opt.dataset.name;
        }
      }
    });
    var form = sel.closest('form');
    if (form) {
      form.addEventListener('submit', function() {
        if (sel.value === 'custom') {
          var ci = document.getElementById('level-custom-input');
          var hiddenInput = document.createElement('input');
          hiddenInput.type = 'hidden';
          hiddenInput.name = 'level_id';
          hiddenInput.value = ci.value;
          form.appendChild(hiddenInput);
        }
      });
    }
  }
})();

function editLevel(levelId, name, allowed, dailyLimit) {
  var sel = document.getElementById('level-select');
  var customInput = document.getElementById('level-custom-input');
  var nameInput = document.getElementById('level-name');
  var allowedSelect = document.querySelector('select[name="allowed"]');
  var dailyLimitInput = document.querySelector('input[name="daily_limit"]');

  if (sel) {
    var found = false;
    for (var i = 0; i < sel.options.length; i++) {
      if (sel.options[i].value == levelId) {
        sel.value = levelId;
        found = true;
        break;
      }
    }
    if (!found) {
      sel.value = 'custom';
      if (customInput) {
        customInput.classList.remove('hidden');
        customInput.required = true;
        customInput.value = levelId;
      }
    } else {
      if (customInput) {
        customInput.classList.add('hidden');
        customInput.required = false;
      }
    }
  } else {
    var levelIdInput = document.querySelector('input[name="level_id"]');
    if (levelIdInput) levelIdInput.value = levelId;
  }

  if (nameInput) nameInput.value = name;
  if (allowedSelect) allowedSelect.value = allowed ? 'true' : 'false';
  if (dailyLimitInput) dailyLimitInput.value = dailyLimit;

  var formCard = document.querySelector('form[action="/access/add"]');
  if (formCard) {
    formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}
</script>
    </main>
  </div>
</body>
</html>
