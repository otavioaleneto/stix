<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="mb-6">
        <a href="/events" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Voltar
        </a>
      </div>

      <% if (error) { %>
      <div class="mb-6 rounded-lg bg-red-900/50 border border-red-500/50 p-4">
        <p class="text-sm text-red-300"><%= error %></p>
      </div>
      <% } %>

      <form action="<%= event && event.id ? '/events/' + event.id : '/events' %>" method="POST" class="space-y-6">

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <h3 class="text-lg font-medium text-white mb-4"><%= event && event.id ? 'Editar Evento' : 'Novo Evento' %></h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">T&iacute;tulo</label>
              <input type="text" name="title" value="<%= event ? event.title : '' %>" required
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                placeholder="Título do evento">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Descri&ccedil;&atilde;o (opcional)</label>
              <textarea name="description" rows="5"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                placeholder="Descreva o evento..."><%= event ? (event.description || '') : '' %></textarea>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Tipo do Evento</label>
                <select name="event_type"
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
                  <% if (eventTypes && eventTypes.length > 0) { %>
                    <% eventTypes.forEach(function(et) { %>
                    <option value="<%= et.slug %>" <%= event && event.event_type === et.slug ? 'selected' : (!event && et.slug === 'outro' ? 'selected' : '') %>><%= et.name %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="outro" <%= event && event.event_type === 'outro' ? 'selected' : (!event ? 'selected' : '') %>>Outro</option>
                    <option value="sorteio" <%= event && event.event_type === 'sorteio' ? 'selected' : '' %>>Sorteio</option>
                    <option value="live" <%= event && event.event_type === 'live' ? 'selected' : '' %>>Live</option>
                    <option value="torneio" <%= event && event.event_type === 'torneio' ? 'selected' : '' %>>Torneio</option>
                  <% } %>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Data do Evento</label>
                <input type="datetime-local" name="event_date"
                  value="<%= event && event.event_date ? new Date(event.event_date).toISOString().slice(0, 16) : '' %>"
                  class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">URL do Evento (opcional)</label>
              <input type="url" name="event_url" value="<%= event ? (event.event_url || '') : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                placeholder="https://exemplo.com/evento">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Imagem de Capa (opcional)</label>
              <div class="flex gap-2">
                <input type="url" name="cover_image_url" id="cover_image_url" value="<%= event ? (event.cover_image_url || '') : '' %>"
                  class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                  placeholder="https://exemplo.com/imagem.jpg">
                <label class="inline-flex items-center gap-2 rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors cursor-pointer">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
                  Upload
                  <input type="file" accept="image/jpeg,image/png,image/gif,image/webp" class="hidden" id="coverUploadInput">
                </label>
              </div>
              <p class="mt-1 text-xs text-gray-500" id="uploadStatus"></p>
              <div id="coverPreview" class="mt-2 <%= event && event.cover_image_url ? '' : 'hidden' %>">
                <img src="<%= event && event.cover_image_url ? event.cover_image_url : '' %>" alt="Preview" class="h-32 rounded-lg object-cover" id="coverPreviewImg">
              </div>
            </div>
            <div>
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="hidden" name="published" value="0">
                <input type="checkbox" name="published" value="1" <%= event && event.published ? 'checked' : '' %>
                  class="h-5 w-5 rounded border-gray-600 bg-gray-700 text-brand-500 focus:ring-brand-500">
                <span class="text-sm font-medium text-gray-300">Publicado</span>
              </label>
              <p class="mt-1 text-xs text-gray-500">Marque para tornar o evento vis&iacute;vel na WebUI</p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end gap-3">
          <a href="/events" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Cancelar</a>
          <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
            <%= event && event.id ? 'Salvar' : 'Criar Evento' %>
          </button>
        </div>

      </form>

      <script>
      document.getElementById('coverUploadInput').addEventListener('change', function() {
        var file = this.files[0];
        if (!file) return;
        var status = document.getElementById('uploadStatus');
        status.textContent = 'Enviando...';
        status.className = 'mt-1 text-xs text-yellow-400';
        var formData = new FormData();
        formData.append('image', file);
        fetch('/events/upload', { method: 'POST', body: formData })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              document.getElementById('cover_image_url').value = data.url;
              document.getElementById('coverPreviewImg').src = data.url;
              document.getElementById('coverPreview').classList.remove('hidden');
              status.textContent = 'Upload concluído!';
              status.className = 'mt-1 text-xs text-green-400';
            } else {
              status.textContent = 'Erro: ' + (data.error || 'Falha no upload');
              status.className = 'mt-1 text-xs text-red-400';
            }
          })
          .catch(function(err) {
            status.textContent = 'Erro: ' + err.message;
            status.className = 'mt-1 text-xs text-red-400';
          });
      });

      document.getElementById('cover_image_url').addEventListener('input', function() {
        var url = this.value;
        var preview = document.getElementById('coverPreview');
        var img = document.getElementById('coverPreviewImg');
        if (url) {
          img.src = url;
          preview.classList.remove('hidden');
        } else {
          preview.classList.add('hidden');
        }
      });
      </script>

    </main>
  </div>
</body>
</html>
