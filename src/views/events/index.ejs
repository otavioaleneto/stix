<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Eventos</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <script>
      function deleteEvent(eventId, eventTitle, ev) {
        if (ev) { ev.preventDefault(); ev.stopPropagation(); }
        if (confirm('Tem certeza que deseja excluir o evento "' + eventTitle + '"?\nEsta ação não pode ser desfeita.')) {
          var form = document.createElement('form');
          form.method = 'POST';
          form.action = '/events/' + eventId + '/delete';
          document.body.appendChild(form);
          form.submit();
        }
      }
      </script>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Eventos</h1>
          <p class="mt-1 text-sm text-gray-400"><%= totalEvents %> evento(s) no total</p>
        </div>
        <a href="/events/new" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Evento
        </a>
      </div>

      <div class="mb-6 flex flex-col sm:flex-row gap-2 items-start sm:items-center">
        <form action="/events" method="GET" class="flex gap-2 flex-1">
          <input type="text" name="search" value="<%= search %>" placeholder="Buscar eventos..."
            class="flex-1 rounded-lg bg-gray-800 border border-gray-700 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
          <input type="hidden" name="limit" value="<%= perPage %>">
          <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Buscar</button>
          <% if (search) { %>
          <a href="/events?limit=<%= perPage %>" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Limpar</a>
          <% } %>
        </form>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-400">Por p&aacute;gina:</span>
          <% [15, 30, 50].forEach(function(n) { %>
          <a href="/events?limit=<%= n %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
            class="rounded-lg px-3 py-1.5 text-sm font-medium transition-colors <%= perPage === n ? 'bg-brand-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>"><%= n %></a>
          <% }) %>
        </div>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-700">
          <thead class="bg-gray-800/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">T&iacute;tulo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Tipo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Data</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">A&ccedil;&otilde;es</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (events.length === 0) { %>
            <tr>
              <td colspan="5" class="px-6 py-12 text-center text-gray-400">
                <p class="text-lg mb-2">Nenhum evento encontrado</p>
                <a href="/events/new" class="text-brand-400 hover:text-brand-300">Criar primeiro evento</a>
              </td>
            </tr>
            <% } %>
            <% events.forEach(function(event) { %>
            <tr class="hover:bg-gray-700/50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if (event.cover_image_url) { %>
                  <img src="<%= event.cover_image_url %>" alt="" class="h-10 w-14 rounded object-cover flex-shrink-0">
                  <% } %>
                  <div>
                    <p class="text-sm font-medium text-white"><%= event.title %></p>
                    <% if (event.event_url) { %>
                    <p class="text-xs text-blue-400 mt-0.5 truncate max-w-xs"><%= event.event_url %></p>
                    <% } %>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <% var et = typeMap[event.event_type]; %>
                <% if (et) { %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border" style="background-color: <%= et.color %>22; color: <%= et.color %>; border-color: <%= et.color %>55;">
                  <%= et.name %>
                </span>
                <% } else { %>
                <span class="inline-flex items-center rounded-full bg-gray-900/50 px-2.5 py-0.5 text-xs font-medium text-gray-400 border border-gray-500/30">
                  <%= event.event_type %>
                </span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-300">
                <% if (event.event_date) { %>
                <%= new Date(event.event_date).toLocaleDateString('pt-BR') %>
                <% } else { %>
                -
                <% } %>
              </td>
              <td class="px-6 py-4">
                <% if (event.published) { %>
                <span class="inline-flex items-center rounded-full bg-green-900/50 px-2.5 py-0.5 text-xs font-medium text-green-400 border border-green-500/30">Publicado</span>
                <% } else { %>
                <span class="inline-flex items-center rounded-full bg-yellow-900/50 px-2.5 py-0.5 text-xs font-medium text-yellow-400 border border-yellow-500/30">Rascunho</span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/events/<%= event.id %>/edit" class="rounded-lg bg-gray-700 p-2 text-gray-300 hover:text-white hover:bg-gray-600 transition-colors" title="Editar">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                  </a>
                  <button onclick="deleteEvent(<%= event.id %>, '<%= event.title.replace(/'/g, "\\'") %>', event)" class="rounded-lg bg-gray-700 p-2 text-red-400 hover:text-red-300 hover:bg-red-900/30 transition-colors" title="Excluir">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                  </button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <div class="mt-6 flex items-center justify-between">
        <p class="text-sm text-gray-400">P&aacute;gina <%= currentPage %> de <%= totalPages %></p>
        <div class="flex gap-1">
          <%
          var qp = (search ? '&search=' + encodeURIComponent(search) : '') + '&limit=' + perPage;
          var pages = [];
          pages.push(1);
          for (var i = Math.max(2, currentPage - 3); i <= Math.min(totalPages - 1, currentPage + 3); i++) {
            pages.push(i);
          }
          if (totalPages > 1) pages.push(totalPages);
          var uniquePages = [];
          pages.forEach(function(p) { if (uniquePages.indexOf(p) === -1) uniquePages.push(p); });
          uniquePages.sort(function(a,b){ return a-b; });
          var prev = 0;
          %>
          <% if (currentPage > 1) { %>
          <a href="/events?page=<%= currentPage - 1 %><%= qp %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors">&laquo;</a>
          <% } %>
          <% uniquePages.forEach(function(p) { %>
            <% if (prev && p - prev > 1) { %>
            <span class="px-2 py-2 text-sm text-gray-500">&hellip;</span>
            <% } %>
            <% if (p === currentPage) { %>
            <span class="rounded-lg bg-brand-600 px-3 py-2 text-sm font-medium text-white"><%= p %></span>
            <% } else { %>
            <a href="/events?page=<%= p %><%= qp %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors"><%= p %></a>
            <% } %>
            <% prev = p; %>
          <% }) %>
          <% if (currentPage < totalPages) { %>
          <a href="/events?page=<%= currentPage + 1 %><%= qp %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors">&raquo;</a>
          <% } %>
        </div>
      </div>
      <% } %>

    </main>
  </div>
</body>
</html>
