<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="mb-6">
        <a href="/events/types" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Voltar
        </a>
      </div>

      <% if (error) { %>
      <div class="mb-6 rounded-lg bg-red-900/50 border border-red-500/50 p-4">
        <p class="text-sm text-red-300"><%= error %></p>
      </div>
      <% } %>

      <form action="<%= eventType && eventType.id ? '/events/types/' + eventType.id : '/events/types' %>" method="POST" class="space-y-6">

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <h3 class="text-lg font-medium text-white mb-4"><%= eventType && eventType.id ? 'Editar Tipo de Evento' : 'Novo Tipo de Evento' %></h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Nome</label>
              <input type="text" name="name" value="<%= eventType ? eventType.name : '' %>" required
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                placeholder="Nome do tipo de evento">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Cor</label>
              <div class="flex items-center gap-3">
                <input type="color" name="color" value="<%= eventType ? (eventType.color || '#8b8ba3') : '#8b8ba3' %>"
                  class="h-10 w-14 rounded border border-gray-600 bg-gray-700 cursor-pointer" id="colorPicker">
                <input type="text" id="colorText" value="<%= eventType ? (eventType.color || '#8b8ba3') : '#8b8ba3' %>" readonly
                  class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white text-sm w-32">
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end gap-3">
          <a href="/events/types" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Cancelar</a>
          <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
            <%= eventType && eventType.id ? 'Salvar' : 'Criar Tipo' %>
          </button>
        </div>

      </form>

      <script>
      document.getElementById('colorPicker').addEventListener('input', function() {
        document.getElementById('colorText').value = this.value;
      });
      </script>

    </main>
  </div>
</body>
</html>
