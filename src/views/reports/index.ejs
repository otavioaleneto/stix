<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports - GODSend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { theme: { extend: { colors: { brand: { 50: '#f0fdf4', 100: '#dcfce7', 200: '#bbf7d0', 300: '#86efac', 400: '#4ade80', 500: '#22c55e', 600: '#16a34a', 700: '#15803d', 800: '#166534', 900: '#14532d' } } } } }</script>
</head>
<body class="bg-gray-900 min-h-screen">
  <%- include('../partials/sidebar') %>
  <%- include('../partials/navbar') %>
  <div class="lg:pl-64 sidebar-content-area">
    <main class="p-6 mt-16">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Reports</h1>
          <p class="text-sm text-gray-400 mt-1"><%= total %> report(s) registrado(s)</p>
        </div>
      </div>

      <% if (typeCounts.length > 0) { %>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3 mb-6">
        <a href="/reports" class="rounded-lg bg-gray-800 border border-gray-700 p-3 text-center hover:border-brand-500 transition-colors <%= !filterType ? 'border-brand-500 ring-1 ring-brand-500' : '' %>">
          <p class="text-lg font-bold text-white"><%= total %></p>
          <p class="text-xs text-gray-400">Todos</p>
        </a>
        <% typeCounts.forEach(function(tc) { %>
        <a href="/reports?file_type=<%= tc.file_type %>" class="rounded-lg bg-gray-800 border border-gray-700 p-3 text-center hover:border-brand-500 transition-colors <%= filterType === tc.file_type ? 'border-brand-500 ring-1 ring-brand-500' : '' %>">
          <p class="text-lg font-bold text-white"><%= tc.count %></p>
          <p class="text-xs text-gray-400 uppercase"><%= tc.file_type || 'N/A' %></p>
        </a>
        <% }) %>
      </div>
      <% } %>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-700">
            <thead class="bg-gray-800/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">Jogo</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase">Arquivo</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-400 uppercase">Tipo Arquivo</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-400 uppercase">Problema</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-400 uppercase">Console/User</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-400 uppercase">Data</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-400 uppercase">Acao</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <% if (reports.length === 0) { %>
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-gray-500">Nenhum report encontrado.</td>
              </tr>
              <% } %>
              <% reports.forEach(function(report) { %>
              <tr class="hover:bg-gray-700/30">
                <td class="px-4 py-3 text-sm text-white"><%= report.game_title || 'N/A' %></td>
                <td class="px-4 py-3 text-sm text-gray-300 max-w-[200px] truncate"><%= report.file_name || 'N/A' %></td>
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                    <% if (report.file_type === 'game') { %>bg-blue-500/10 text-blue-400
                    <% } else if (report.file_type === 'dlc') { %>bg-purple-500/10 text-purple-400
                    <% } else if (report.file_type === 'tu') { %>bg-yellow-500/10 text-yellow-400
                    <% } else { %>bg-gray-500/10 text-gray-400<% } %>">
                    <%= (report.file_type || 'N/A').toUpperCase() %>
                  </span>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                    <%= report.report_type === 'wrong' ? 'bg-orange-500/10 text-orange-400' : 'bg-red-500/10 text-red-400' %>">
                    <%= report.report_type === 'wrong' ? 'Item Errado' : 'Item Corrompido' %>
                  </span>
                </td>
                <td class="px-4 py-3 text-center text-xs text-gray-400">
                  <% if (report.user_id) { %>User #<%= report.user_id %><% } else if (report.console_id) { %><%= report.console_id.substring(0, 12) %>...<% } else { %>N/A<% } %>
                </td>
                <td class="px-4 py-3 text-center text-xs text-gray-400">
                  <%= report.createdAt ? new Date(report.createdAt).toLocaleDateString('pt-BR') : 'N/A' %>
                </td>
                <td class="px-4 py-3 text-center">
                  <form method="POST" action="/reports/<%= report.id %>/delete" class="inline" onsubmit="return confirm('Remover este report?')">
                    <button type="submit" class="text-red-400 hover:text-red-300 transition-colors" title="Remover">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="px-4 py-3 border-t border-gray-700 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-400">Itens por pagina:</span>
            <% [15, 30, 50].forEach(function(val) { %>
            <a href="/reports?limit=<%= val %>&page=1<%= filterType ? '&file_type=' + filterType : '' %>"
              class="rounded-lg px-3 py-1.5 text-sm font-medium transition-colors <%= val === limit ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
              <%= val %>
            </a>
            <% }) %>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-gray-400">Pagina <%= currentPage %> de <%= totalPages %></span>
            <% if (totalPages > 1) { %>
            <div class="flex gap-1">
              <% if (currentPage > 1) { %>
              <a href="/reports?page=<%= currentPage - 1 %>&limit=<%= limit %><%= filterType ? '&file_type=' + filterType : '' %>"
                class="px-3 py-1 rounded text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600">&laquo;</a>
              <% } %>
              <% var startPage = Math.max(1, currentPage - 2); var endPage = Math.min(totalPages, currentPage + 2); %>
              <% if (startPage > 1) { %>
              <a href="/reports?page=1&limit=<%= limit %><%= filterType ? '&file_type=' + filterType : '' %>"
                class="px-3 py-1 rounded text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600">1</a>
              <% if (startPage > 2) { %><span class="px-2 py-1 text-sm text-gray-500">...</span><% } %>
              <% } %>
              <% for (var p = startPage; p <= endPage; p++) { %>
              <a href="/reports?page=<%= p %>&limit=<%= limit %><%= filterType ? '&file_type=' + filterType : '' %>"
                class="px-3 py-1 rounded text-sm font-medium <%= p === currentPage ? 'bg-brand-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">
                <%= p %>
              </a>
              <% } %>
              <% if (endPage < totalPages) { %>
              <% if (endPage < totalPages - 1) { %><span class="px-2 py-1 text-sm text-gray-500">...</span><% } %>
              <a href="/reports?page=<%= totalPages %>&limit=<%= limit %><%= filterType ? '&file_type=' + filterType : '' %>"
                class="px-3 py-1 rounded text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600"><%= totalPages %></a>
              <% } %>
              <% if (currentPage < totalPages) { %>
              <a href="/reports?page=<%= currentPage + 1 %>&limit=<%= limit %><%= filterType ? '&file_type=' + filterType : '' %>"
                class="px-3 py-1 rounded text-sm font-medium bg-gray-700 text-gray-300 hover:bg-gray-600">&raquo;</a>
              <% } %>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
