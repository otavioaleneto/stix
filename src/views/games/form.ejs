<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="mb-6">
        <a href="/games" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Voltar
        </a>
      </div>

      <% if (error) { %>
      <div class="mb-6 rounded-lg bg-red-900/50 border border-red-500/50 p-4">
        <p class="text-sm text-red-300"><%= error %></p>
      </div>
      <% } %>

      <form action="<%= game && game.id ? '/games/' + game.id : '/games' %>" method="POST" enctype="multipart/form-data" class="space-y-6">

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <h3 class="text-lg font-medium text-white mb-4">Informações do Game</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-gray-300 mb-1">Título</label>
              <input type="text" name="title" value="<%= game ? game.title : '' %>" required
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Plataforma</label>
              <select name="platform" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
                <% platforms.forEach(function(p) { %>
                <option value="<%= p.value %>" <%= game && game.platform === p.value ? 'selected' : '' %>><%= p.label %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Status</label>
              <select name="status" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
                <option value="active" <%= !game || game.status === 'active' ? 'selected' : '' %>>Ativo</option>
                <option value="inactive" <%= game && game.status === 'inactive' ? 'selected' : '' %>>Inativo</option>
                <option value="standby" <%= game && game.status === 'standby' ? 'selected' : '' %>>Standby</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Title ID</label>
              <input type="text" name="title_id" value="<%= game ? game.title_id || '' : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm" placeholder="Ex: 55530871">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Produtora</label>
              <input type="text" name="publisher" value="<%= game ? game.publisher || '' : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm" placeholder="Ex: Ubisoft">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Data de Lançamento</label>
              <input type="date" name="release_date" value="<%= game && game.release_date ? (typeof game.release_date === 'string' ? game.release_date : game.release_date.toISOString().split('T')[0]) : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 text-sm">
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-gray-300 mb-1">Trailer do YouTube (URL)</label>
              <input type="url" name="youtube_trailer_url" value="<%= game ? game.youtube_trailer_url || '' : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm" placeholder="https://www.youtube.com/watch?v=...">
            </div>
            <div class="sm:col-span-2">
              <div class="flex items-center gap-2 mb-2">
                <label class="block text-sm font-medium text-gray-300">Categorias</label>
                <button type="button" onclick="openNewCategoryModal()" class="inline-flex items-center justify-center h-5 w-5 rounded bg-brand-600 text-white hover:bg-brand-500 transition-colors" title="Nova categoria">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                </button>
              </div>
              <div id="categories-container" class="flex flex-wrap gap-3">
                <% if (categoryAttrs && categoryAttrs.length > 0) { %>
                <% categoryAttrs.forEach(function(cat) { %>
                <label class="inline-flex items-center gap-2 cursor-pointer bg-gray-700/50 border border-gray-600 rounded-lg px-3 py-1.5 hover:bg-gray-700 transition-colors">
                  <input type="checkbox" name="categories" value="<%= cat.value %>"
                    <%= gameCategories && gameCategories.indexOf(cat.value) !== -1 ? 'checked' : '' %>
                    class="rounded bg-gray-600 border-gray-500 text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
                  <span class="text-sm text-gray-300"><%= cat.label %></span>
                </label>
                <% }) %>
                <% } %>
              </div>
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-gray-300 mb-1">Descrição</label>
              <textarea name="description" rows="4"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm" placeholder="Descrição do game..."><%= game ? game.description || '' : '' %></textarea>
            </div>
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-gray-300 mb-2">Capa</label>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="flex items-start justify-center">
                  <% if (game && game.cover_image) { %>
                  <img id="cover-preview" src="<%= game.cover_image %>" alt="" class="h-40 w-28 rounded-lg object-cover border border-gray-600">
                  <% } else { %>
                  <div id="cover-preview-wrap" class="hidden">
                    <img id="cover-preview" src="" alt="" class="h-40 w-28 rounded-lg object-cover border border-gray-600">
                  </div>
                  <div id="cover-placeholder" class="h-40 w-28 rounded-lg border-2 border-dashed border-gray-600 flex items-center justify-center">
                    <svg class="h-10 w-10 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 6.75v10.5A2.25 2.25 0 003.75 21z" /></svg>
                  </div>
                  <% } %>
                </div>
                <div>
                  <p class="text-xs text-gray-400 mb-2">Upload de arquivo</p>
                  <input type="file" name="cover_image" accept="image/*"
                    class="w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-gray-700 file:text-white hover:file:bg-gray-600">
                </div>
                <div>
                  <p class="text-xs text-gray-400 mb-2">URL externa</p>
                  <input type="url" name="cover_image_url" id="cover-url-input" value="<%= (game && game.cover_image && game.cover_image.startsWith('http')) ? game.cover_image : '' %>"
                    class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm" placeholder="https://exemplo.com/capa.jpg"
                    oninput="previewCoverUrl(this.value)">
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-medium text-white">Arquivos</h3>
            <button type="button" onclick="addFileRow()" class="inline-flex items-center gap-1 rounded-lg bg-gray-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
              Adicionar Arquivo
            </button>
          </div>
          <p class="text-xs text-gray-400 mb-4">Caminho no console = destino no Xbox. Selecione "Content/00.../" para preencher apenas o Title ID, ou "Caminho livre" para um caminho personalizado.</p>

          <div id="files-container" class="space-y-4">
            <% if (files && files.length > 0) { %>
              <% files.forEach((file, index) => { %>
              <div class="file-row rounded-lg bg-gray-700/50 border border-gray-600 p-4" data-index="<%= index %>">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm font-medium text-gray-300">Arquivo #<%= index + 1 %></span>
                  <button type="button" onclick="this.closest('.file-row').remove()" class="text-red-400 hover:text-red-300">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  <div>
                    <label class="block text-xs text-gray-400 mb-1">Nome/Label</label>
                    <input type="text" name="file_labels" value="<%= file.label %>" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500">
                  </div>
                  <div>
                    <label class="block text-xs text-gray-400 mb-1">Tipo</label>
                    <select name="file_types" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500">
                      <% fileTypes.forEach(function(ft) { %>
                      <option value="<%= ft.value %>" <%= file.file_type === ft.value ? 'selected' : '' %>><%= ft.label %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs text-gray-400 mb-1">Tamanho</label>
                    <div class="flex gap-2">
                      <input type="number" step="any" name="file_sizes" value="<%= file.file_size ? (file.file_size >= 1073741824 ? (file.file_size / 1073741824).toFixed(2) : file.file_size >= 1048576 ? (file.file_size / 1048576).toFixed(2) : (file.file_size / 1024).toFixed(2)) : '' %>" class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: 4.50">
                      <select name="file_size_units" class="w-20 rounded-lg bg-gray-700 border border-gray-600 px-2 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500">
                        <option value="KB" <%= file.file_size && file.file_size < 1048576 ? 'selected' : '' %>>KB</option>
                        <option value="MB" <%= file.file_size && file.file_size >= 1048576 && file.file_size < 1073741824 ? 'selected' : '' %>>MB</option>
                        <option value="GB" <%= !file.file_size || file.file_size >= 1073741824 ? 'selected' : '' %>>GB</option>
                      </select>
                    </div>
                  </div>
                  <div>
                    <label class="block text-xs text-gray-400 mb-1">Media ID</label>
                    <input type="text" name="file_media_ids" value="<%= file.media_id || '' %>" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: 12345678">
                  </div>
                  <div class="sm:col-span-2 lg:col-span-3">
                    <label class="block text-xs text-gray-400 mb-1">Caminho no Servidor (WebDAV)</label>
                    <div class="flex gap-2">
                      <input type="text" name="file_server_paths" value="<%= file.server_path %>" class="webdav-path-input flex-1 rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Cole o link ou navegue pelas pastas">
                      <button type="button" onclick="openBrowser(this)" class="shrink-0 rounded-lg bg-brand-600 px-3 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors flex items-center gap-1.5" title="Navegar nas pastas do WebDAV">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
                        Navegar
                      </button>
                    </div>
                  </div>
                  <div class="sm:col-span-2 lg:col-span-3">
                    <label class="block text-xs text-gray-400 mb-1">Caminho no Console (destino)</label>
                    <input type="hidden" name="file_folder_paths" value="<%= file.folder_path || '' %>">
                    <div class="flex gap-2">
                      <select class="folder-prefix-select rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500 shrink-0" onchange="updateFolderPath(this)">
                        <option value="Content/0000000000000000/" <%= (file.folder_path || '').startsWith('Content/0000000000000000/') ? 'selected' : '' %>>Content/00.../</option>
                        <option value="" <%= !(file.folder_path || '').startsWith('Content/0000000000000000/') ? 'selected' : '' %>>Caminho livre</option>
                      </select>
                      <input type="text" class="folder-suffix-input w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" value="<%= (file.folder_path || '').startsWith('Content/0000000000000000/') ? (file.folder_path || '').replace('Content/0000000000000000/', '') : (file.folder_path || '') %>" placeholder="<%= (file.folder_path || '').startsWith('Content/0000000000000000/') ? 'Ex: 55530871' : 'Ex: Content/0000000000000000/55530871' %>" oninput="updateFolderPath(this)">
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <button type="submit" id="save-btn" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
            <%= game && game.id ? 'Salvar Alterações' : 'Cadastrar Game' %>
          </button>
          <% if (game && game.id) { %>
          <button type="button" id="ai-complete-btn" onclick="aiComplete()" class="rounded-lg bg-purple-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-purple-500 transition-colors inline-flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
            Auto-completar com IA
          </button>
          <% } %>
          <a href="/games" class="rounded-lg bg-gray-700 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Cancelar</a>
        </div>
      </form>

      <div id="toast" class="fixed top-6 right-6 z-[200] hidden">
        <div id="toast-content" class="flex items-center gap-3 rounded-xl px-5 py-3 shadow-2xl border">
          <span id="toast-icon"></span>
          <span id="toast-msg" class="text-sm font-medium"></span>
        </div>
      </div>

      <div id="newCategoryModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60">
        <div class="bg-gray-800 border border-gray-700 rounded-xl w-full max-w-sm mx-4 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-white">Nova Categoria</h3>
            <button type="button" onclick="closeNewCategoryModal()" class="text-gray-400 hover:text-white">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Nome da Categoria</label>
              <input type="text" id="new-category-name" placeholder="Ex: RPG, Corrida, Acao..."
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 text-sm">
            </div>
            <div class="flex items-center gap-3">
              <button type="button" onclick="createCategory()" id="create-category-btn" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">Criar</button>
              <button type="button" onclick="closeNewCategoryModal()" class="rounded-lg bg-gray-700 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Cancelar</button>
            </div>
          </div>
        </div>
      </div>

      <div id="webdav-modal" class="fixed inset-0 z-[100] hidden">
        <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" onclick="closeBrowser()"></div>
        <div class="fixed inset-4 sm:inset-8 lg:inset-y-12 lg:inset-x-24 z-[101] flex flex-col rounded-2xl bg-gray-800 border border-gray-700 shadow-2xl overflow-hidden">

          <div class="flex items-center justify-between px-5 py-4 border-b border-gray-700">
            <div class="flex items-center gap-3">
              <svg class="h-5 w-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
              <h3 class="text-lg font-semibold text-white">Navegar no WebDAV</h3>
            </div>
            <button type="button" onclick="closeBrowser()" class="text-gray-400 hover:text-white transition-colors">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>

          <div class="px-5 py-3 border-b border-gray-700 bg-gray-800/50">
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 shrink-0">Caminho:</span>
              <div id="breadcrumb" class="flex items-center gap-1 text-sm overflow-x-auto whitespace-nowrap scrollbar-hide"></div>
            </div>
          </div>

          <div id="browser-loading" class="hidden px-5 py-8 text-center">
            <svg class="animate-spin h-8 w-8 text-brand-400 mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <p class="text-sm text-gray-400 mt-3">Carregando...</p>
          </div>

          <div id="browser-error" class="hidden px-5 py-8 text-center">
            <svg class="h-10 w-10 text-red-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
            <p id="browser-error-msg" class="text-sm text-red-300 mt-3"></p>
            <p class="text-xs text-gray-400 mt-2">Verifique se o WebDAV está configurado nas Configurações.</p>
          </div>

          <div id="browser-content" class="flex-1 overflow-y-auto px-2 py-2">
            <div id="browser-list" class="space-y-0.5"></div>
          </div>

          <div class="px-5 py-3 border-t border-gray-700 bg-gray-800/50">
            <div class="flex items-center justify-between gap-3">
              <div class="flex-1 min-w-0">
                <p class="text-xs text-gray-400">Pasta selecionada:</p>
                <p id="selected-path-display" class="text-sm text-white font-mono truncate">/</p>
              </div>
              <div class="flex gap-2 shrink-0">
                <button type="button" onclick="closeBrowser()" class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Cancelar</button>
                <button type="button" onclick="confirmSelection()" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Selecionar esta pasta</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <script>
      var fileCount = document.querySelectorAll('.file-row').length;
      var activePathInput = null;
      var currentBrowserPath = '/';
      var fileTypeOptions = '<% fileTypes.forEach(function(ft) { %><option value="<%= ft.value %>"><%= ft.label %></option><% }) %>';

      function previewCoverUrl(url) {
        var preview = document.getElementById('cover-preview');
        var wrap = document.getElementById('cover-preview-wrap');
        var placeholder = document.getElementById('cover-placeholder');
        if (url && (url.startsWith('http://') || url.startsWith('https://'))) {
          preview.src = url;
          preview.onerror = function() { if (wrap) wrap.classList.add('hidden'); if (placeholder) placeholder.classList.remove('hidden'); };
          preview.onload = function() { if (wrap) wrap.classList.remove('hidden'); if (placeholder) placeholder.classList.add('hidden'); };
          if (wrap) wrap.classList.remove('hidden');
          if (placeholder) placeholder.classList.add('hidden');
        } else {
          if (wrap) wrap.classList.add('hidden');
          if (placeholder) placeholder.classList.remove('hidden');
        }
      }

      function updateFolderPath(el) {
        var wrapper = el.closest('.flex');
        if (!wrapper) return;
        var parent = wrapper.parentElement;
        var selectEl = wrapper.querySelector('.folder-prefix-select');
        var suffixInput = wrapper.querySelector('.folder-suffix-input');
        var hiddenInput = parent.querySelector('input[name="file_folder_paths"]');
        if (!selectEl || !suffixInput || !hiddenInput) return;
        var prefix = selectEl.value;
        var suffix = suffixInput.value.trim();
        hiddenInput.value = prefix + suffix;
        if (prefix === 'Content/0000000000000000/') {
          suffixInput.placeholder = 'Ex: 55530871';
        } else {
          suffixInput.placeholder = 'Ex: Content/0000000000000000/55530871';
        }
      }

      function addFileRow() {
        fileCount++;
        const container = document.getElementById('files-container');
        const html = `
        <div class="file-row rounded-lg bg-gray-700/50 border border-gray-600 p-4">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm font-medium text-gray-300">Arquivo #${fileCount}</span>
            <button type="button" onclick="this.closest('.file-row').remove()" class="text-red-400 hover:text-red-300">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Nome/Label</label>
              <input type="text" name="file_labels" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: Jogo Principal">
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Tipo</label>
              <select name="file_types" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500">
                ${fileTypeOptions}
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Tamanho</label>
              <div class="flex gap-2">
                <input type="number" step="any" name="file_sizes" class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: 4.50">
                <select name="file_size_units" class="w-20 rounded-lg bg-gray-700 border border-gray-600 px-2 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500">
                  <option value="KB">KB</option>
                  <option value="MB">MB</option>
                  <option value="GB" selected>GB</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Media ID</label>
              <input type="text" name="file_media_ids" class="w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: 12345678">
            </div>
            <div class="sm:col-span-2 lg:col-span-3">
              <label class="block text-xs text-gray-400 mb-1">Caminho no Servidor (WebDAV)</label>
              <div class="flex gap-2">
                <input type="text" name="file_server_paths" class="webdav-path-input flex-1 rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Cole o link ou navegue pelas pastas">
                <button type="button" onclick="openBrowser(this)" class="shrink-0 rounded-lg bg-brand-600 px-3 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors flex items-center gap-1.5" title="Navegar nas pastas do WebDAV">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
                  Navegar
                </button>
              </div>
            </div>
            <div class="sm:col-span-2 lg:col-span-3">
              <label class="block text-xs text-gray-400 mb-1">Caminho no Console (destino)</label>
              <input type="hidden" name="file_folder_paths" value="">
              <div class="flex gap-2">
                <select class="folder-prefix-select rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500 shrink-0" onchange="updateFolderPath(this)">
                  <option value="Content/0000000000000000/" selected>Content/00.../</option>
                  <option value="">Caminho livre</option>
                </select>
                <input type="text" class="folder-suffix-input w-full rounded-lg bg-gray-700 border border-gray-600 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-brand-500" placeholder="Ex: 55530871" oninput="updateFolderPath(this)">
              </div>
            </div>
          </div>
        </div>`;
        container.insertAdjacentHTML('beforeend', html);
      }

      function openBrowser(btn) {
        const row = btn.closest('.file-row') || btn.closest('.grid');
        activePathInput = row.querySelector('input[name="file_server_paths"]');
        const existingPath = activePathInput.value.trim();
        currentBrowserPath = existingPath && existingPath.startsWith('/') ? existingPath : '/';
        document.getElementById('webdav-modal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        navigateTo(currentBrowserPath);
      }

      function closeBrowser() {
        document.getElementById('webdav-modal').classList.add('hidden');
        document.body.style.overflow = '';
        activePathInput = null;
      }

      function confirmSelection() {
        if (activePathInput && currentBrowserPath) {
          activePathInput.value = currentBrowserPath;
        }
        closeBrowser();
      }

      function updateBreadcrumb(path) {
        const container = document.getElementById('breadcrumb');
        const parts = path.split('/').filter(Boolean);
        let html = `<button type="button" onclick="navigateTo('/')" class="text-brand-400 hover:text-brand-300 transition-colors">/</button>`;
        let accumulated = '';
        parts.forEach((part, i) => {
          accumulated += '/' + part;
          const isLast = i === parts.length - 1;
          html += `<span class="text-gray-500">/</span>`;
          if (isLast) {
            html += `<span class="text-white font-medium">${part}</span>`;
          } else {
            html += `<button type="button" onclick="navigateTo('${accumulated}')" class="text-brand-400 hover:text-brand-300 transition-colors">${part}</button>`;
          }
        });
        container.innerHTML = html;
      }

      function formatSize(bytes) {
        if (!bytes || bytes === 0) return '';
        const units = ['B', 'KB', 'MB', 'GB'];
        let i = 0;
        while (bytes >= 1024 && i < units.length - 1) { bytes /= 1024; i++; }
        return bytes.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
      }

      async function navigateTo(path) {
        currentBrowserPath = path;
        document.getElementById('selected-path-display').textContent = path;
        updateBreadcrumb(path);

        const loading = document.getElementById('browser-loading');
        const error = document.getElementById('browser-error');
        const content = document.getElementById('browser-content');
        const list = document.getElementById('browser-list');

        loading.classList.remove('hidden');
        error.classList.add('hidden');
        content.classList.add('hidden');

        try {
          const res = await fetch('/games/webdav-browse?path=' + encodeURIComponent(path));
          const data = await res.json();

          loading.classList.add('hidden');

          if (!data.success) {
            error.classList.remove('hidden');
            document.getElementById('browser-error-msg').textContent = data.message || 'Erro ao acessar o WebDAV';
            return;
          }

          content.classList.remove('hidden');
          let html = '';

          if (path !== '/') {
            const parent = path.split('/').slice(0, -1).join('/') || '/';
            html += `
            <button type="button" onclick="navigateTo('${parent}')"
              class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left hover:bg-gray-700/50 transition-colors group">
              <svg class="h-5 w-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" /></svg>
              <span class="text-sm text-gray-300 group-hover:text-white">..</span>
            </button>`;
          }

          if (data.items.length === 0) {
            html += '<p class="text-sm text-gray-400 text-center py-8">Pasta vazia</p>';
          }

          data.items.forEach(item => {
            const isDir = item.type === 'directory';
            const itemPath = item.path.endsWith('/') ? item.path.slice(0, -1) : item.path;
            if (isDir) {
              html += `
              <button type="button" onclick="navigateTo('${itemPath}')"
                class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left hover:bg-gray-700/50 transition-colors group">
                <svg class="h-5 w-5 text-yellow-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" /></svg>
                <span class="flex-1 text-sm text-gray-300 group-hover:text-white truncate">${item.name}</span>
                <svg class="h-4 w-4 text-gray-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
              </button>`;
            } else {
              html += `
              <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg opacity-60">
                <svg class="h-5 w-5 text-gray-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                <span class="flex-1 text-sm text-gray-400 truncate">${item.name}</span>
                <span class="text-xs text-gray-500 shrink-0">${formatSize(item.size)}</span>
              </div>`;
            }
          });

          list.innerHTML = html;
        } catch (e) {
          loading.classList.add('hidden');
          error.classList.remove('hidden');
          document.getElementById('browser-error-msg').textContent = 'Erro de conexão: ' + e.message;
        }
      }

      function showToast(message, type) {
        var toast = document.getElementById('toast');
        var content = document.getElementById('toast-content');
        var icon = document.getElementById('toast-icon');
        var msg = document.getElementById('toast-msg');
        msg.textContent = message;
        if (type === 'success') {
          content.className = 'flex items-center gap-3 rounded-xl px-5 py-3 shadow-2xl border bg-green-900/90 border-green-500/30';
          icon.innerHTML = '<svg class="h-5 w-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>';
          msg.className = 'text-sm font-medium text-green-300';
        } else {
          content.className = 'flex items-center gap-3 rounded-xl px-5 py-3 shadow-2xl border bg-red-900/90 border-red-500/30';
          icon.innerHTML = '<svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>';
          msg.className = 'text-sm font-medium text-red-300';
        }
        toast.classList.remove('hidden');
        clearTimeout(window._toastTimer);
        window._toastTimer = setTimeout(function() { toast.classList.add('hidden'); }, 4000);
      }

      <% if (game && game.id) { %>
      (function() {
        var form = document.querySelector('form[action="/games/<%= game.id %>"]');
        if (!form) return;
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var btn = document.getElementById('save-btn');
          var origText = btn.textContent;
          btn.textContent = 'Salvando...';
          btn.disabled = true;
          var formData = new FormData(form);
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.success) {
              showToast(data.message || 'Salvo com sucesso!', 'success');
            } else {
              showToast(data.message || 'Erro ao salvar', 'error');
            }
          })
          .catch(function(err) {
            showToast('Erro de conexão: ' + err.message, 'error');
          })
          .finally(function() {
            btn.textContent = origText;
            btn.disabled = false;
          });
        });
      })();
      <% } %>

      function aiComplete() {
        var btn = document.getElementById('ai-complete-btn');
        var origHTML = btn.innerHTML;
        btn.innerHTML = '<svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Consultando IA...';
        btn.disabled = true;
        fetch('/games/<%= game ? game.id : "" %>/ai-complete', {
          method: 'POST',
          headers: { 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success && data.data) {
            var d = data.data;
            if (d.description) {
              var descEl = document.querySelector('textarea[name="description"]');
              if (descEl && !descEl.value.trim()) descEl.value = d.description;
            }
            if (d.publisher) {
              var pubEl = document.querySelector('input[name="publisher"]');
              if (pubEl && !pubEl.value.trim()) pubEl.value = d.publisher;
            }
            if (d.release_date) {
              var rdEl = document.querySelector('input[name="release_date"]');
              if (rdEl && !rdEl.value) rdEl.value = d.release_date;
            }
            showToast(data.message || 'Campos preenchidos com IA!', 'success');
          } else {
            showToast(data.message || 'Erro ao consultar IA', 'error');
          }
        })
        .catch(function(err) {
          showToast('Erro: ' + err.message, 'error');
        })
        .finally(function() {
          btn.innerHTML = origHTML;
          btn.disabled = false;
        });
      }

      function openNewCategoryModal() {
        document.getElementById('newCategoryModal').classList.remove('hidden');
        document.getElementById('new-category-name').value = '';
        document.getElementById('new-category-name').focus();
      }

      function closeNewCategoryModal() {
        document.getElementById('newCategoryModal').classList.add('hidden');
      }

      function createCategory() {
        var nameInput = document.getElementById('new-category-name');
        var name = nameInput.value.trim();
        if (!name) { nameInput.focus(); return; }
        var btn = document.getElementById('create-category-btn');
        btn.textContent = 'Criando...';
        btn.disabled = true;
        fetch('/attributes/json', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ category: 'category', label: name })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success && data.attribute) {
            var container = document.getElementById('categories-container');
            var label = document.createElement('label');
            label.className = 'inline-flex items-center gap-2 cursor-pointer bg-gray-700/50 border border-gray-600 rounded-lg px-3 py-1.5 hover:bg-gray-700 transition-colors';
            label.innerHTML = '<input type="checkbox" name="categories" value="' + data.attribute.value + '" checked class="rounded bg-gray-600 border-gray-500 text-brand-500 focus:ring-brand-500 focus:ring-offset-0"><span class="text-sm text-gray-300">' + data.attribute.label + '</span>';
            container.appendChild(label);
            closeNewCategoryModal();
            showToast('Categoria "' + data.attribute.label + '" criada!', 'success');
          } else {
            showToast(data.message || 'Erro ao criar categoria', 'error');
          }
        })
        .catch(function(err) {
          showToast('Erro: ' + err.message, 'error');
        })
        .finally(function() {
          btn.textContent = 'Criar';
          btn.disabled = false;
        });
      }
      </script>

    </main>
  </div>
</body>
</html>
