<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Games</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <script>
      function toggleCsvDropdown() {
        var dropdown = document.getElementById('csv-dropdown');
        dropdown.classList.toggle('hidden');
      }
      function deleteGame(gameId, gameTitle, event) {
        if (event) { event.preventDefault(); event.stopPropagation(); }
        if (confirm('Tem certeza que deseja excluir o game "' + gameTitle + '"?\nEsta ação não pode ser desfeita.')) {
          var form = document.createElement('form');
          form.method = 'POST';
          form.action = '/games/' + gameId + '/delete';
          document.body.appendChild(form);
          form.submit();
        }
      }
      function setViewMode(mode) {
        var gridView = document.getElementById('grid-view');
        var listView = document.getElementById('list-view');
        var btnGrid = document.getElementById('btn-grid-view');
        var btnList = document.getElementById('btn-list-view');
        if (!gridView || !listView) return;
        if (mode === 'list') {
          gridView.classList.add('hidden');
          listView.classList.remove('hidden');
          btnGrid.className = 'rounded-lg p-2 text-sm font-medium transition-colors bg-gray-800 text-gray-400 hover:text-white border border-gray-700';
          btnList.className = 'rounded-lg p-2 text-sm font-medium transition-colors bg-brand-600 text-white';
        } else {
          gridView.classList.remove('hidden');
          listView.classList.add('hidden');
          btnGrid.className = 'rounded-lg p-2 text-sm font-medium transition-colors bg-brand-600 text-white';
          btnList.className = 'rounded-lg p-2 text-sm font-medium transition-colors bg-gray-800 text-gray-400 hover:text-white border border-gray-700';
        }
        try { localStorage.setItem('games_view_mode', mode); } catch(e) {}
      }
      </script>

      <% if (typeof import_success !== 'undefined' && import_success) { %>
      <div class="mb-4 rounded-lg bg-green-500/20 border border-green-500/50 px-4 py-3 text-sm text-green-400">
        <%= import_success %> games importados com sucesso<% if (typeof import_errors !== 'undefined' && import_errors > 0) { %> (<%= import_errors %> erros)<% } %>
      </div>
      <% } %>
      <% if (typeof import_error !== 'undefined' && import_error) { %>
      <div class="mb-4 rounded-lg bg-red-500/20 border border-red-500/50 px-4 py-3 text-sm text-red-400">
        Erro na importação: <%= import_error %>
      </div>
      <% } %>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
          <p class="text-sm text-gray-400"><%= totalGames %> games cadastrados</p>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative" id="csv-dropdown-container">
            <button type="button" onclick="toggleCsvDropdown()" class="inline-flex items-center gap-2 rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-600 transition-colors">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
              CSV
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </button>
            <div id="csv-dropdown" class="hidden absolute right-0 mt-2 w-56 rounded-lg bg-gray-800 border border-gray-700 shadow-xl z-50">
              <div class="py-1">
                <a href="/games/export-csv" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                  <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  Exportar Games (CSV)
                </a>
                <a href="/games/csv-template" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                  <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                  Baixar Template CSV
                </a>
                <div class="border-t border-gray-700 my-1"></div>
                <button type="button" onclick="document.getElementById('csv-file-input').click()" class="flex items-center gap-3 w-full px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors text-left">
                  <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
                  Importar Games (CSV)
                </button>
              </div>
            </div>
          </div>
          <form id="csv-import-form" action="/games/import-csv" method="POST" enctype="multipart/form-data" class="hidden">
            <input type="file" id="csv-file-input" name="csv_file" accept=".csv" onchange="document.getElementById('csv-import-form').submit()">
          </form>
          <a href="/games/new" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            Novo Game
          </a>
        </div>
      </div>

      <form method="GET" action="/games" class="flex flex-col sm:flex-row gap-3 mb-6">
        <input type="text" name="search" value="<%= search %>" placeholder="Buscar por título..."
          class="flex-1 rounded-lg border-0 bg-gray-800 px-4 py-2.5 text-sm text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 border border-gray-700">
        <select name="platform" class="rounded-lg border-0 bg-gray-800 px-4 py-2.5 text-sm text-white focus:ring-2 focus:ring-brand-500 border border-gray-700">
          <option value="">Todas as plataformas</option>
          <% platformAttrs.forEach(function(p) { %>
          <option value="<%= p.value %>" <%= platform === p.value ? 'selected' : '' %>><%= p.label %></option>
          <% }) %>
        </select>
        <input type="hidden" name="limit" value="<%= limit %>">
        <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Buscar</button>
      </form>

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-400">Por página:</span>
          <% [15, 30, 50].forEach(function(val) { %>
          <a href="/games?search=<%= search %>&platform=<%= platform %>&limit=<%= val %>&page=1"
            class="rounded-lg px-3 py-1.5 text-sm font-medium transition-colors <%= val === limit ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
            <%= val %>
          </a>
          <% }) %>
        </div>
        <div class="flex items-center gap-1">
          <button type="button" id="btn-grid-view" onclick="setViewMode('grid')" class="rounded-lg p-2 text-sm font-medium transition-colors bg-brand-600 text-white" title="Visualização em grade">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
          </button>
          <button type="button" id="btn-list-view" onclick="setViewMode('list')" class="rounded-lg p-2 text-sm font-medium transition-colors bg-gray-800 text-gray-400 hover:text-white border border-gray-700" title="Visualização em lista">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" /></svg>
          </button>
        </div>
      </div>

      <% if (games.length === 0) { %>
      <div class="rounded-xl bg-gray-800 border border-gray-700 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" /></svg>
        <h3 class="mt-4 text-sm font-semibold text-white">Nenhum game encontrado</h3>
        <p class="mt-2 text-sm text-gray-400">Comece adicionando seu primeiro game.</p>
        <a href="/games/new" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Adicionar Game
        </a>
      </div>
      <% } else { %>
      <div id="grid-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <% games.forEach(game => { %>
        <a href="/games/<%= game.id %>" class="group rounded-xl bg-gray-800 border border-gray-700 overflow-hidden hover:border-brand-500/50 transition-colors">
          <div class="aspect-[3/4] bg-gray-700 relative overflow-hidden">
            <% if (game.cover_image) { %>
            <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300">
            <% } else { %>
            <div class="h-full w-full flex items-center justify-center">
              <svg class="h-16 w-16 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 6.75v10.5A2.25 2.25 0 003.75 21z" /></svg>
            </div>
            <% } %>
            <div class="absolute top-2 right-2 flex items-center gap-1">
              <button type="button" onclick="deleteGame(<%= game.id %>, '<%= game.title.replace(/'/g, "\\'") %>', event)" class="rounded-full p-1 bg-red-500/80 text-white opacity-0 group-hover:opacity-100 hover:bg-red-600 transition-all" title="Excluir">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
              </button>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= game.status === 'active' ? 'bg-green-500/90 text-white' : game.status === 'standby' ? 'bg-yellow-500/90 text-white' : 'bg-gray-500/90 text-white' %>">
                <%= game.status === 'active' ? 'Ativo' : game.status === 'standby' ? 'Standby' : 'Inativo' %>
              </span>
            </div>
          </div>
          <div class="p-3">
            <h3 class="text-sm font-medium text-white truncate"><%= game.title %></h3>
            <div class="mt-1 flex items-center gap-2 text-xs text-gray-400">
              <span class="capitalize"><%= game.platform.replace('_', ' ') %></span>
              <span>&middot;</span>
              <span><%= game.files ? game.files.length : 0 %> arquivos</span>
              <span>&middot;</span>
              <span class="inline-flex items-center gap-0.5">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                <%= (typeof downloadCountMap !== 'undefined' && downloadCountMap[game.id]) ? downloadCountMap[game.id] : 0 %>
              </span>
              <span>&middot;</span>
              <span class="inline-flex items-center gap-0.5 text-yellow-400">
                <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <% var gr = (typeof ratingMap !== 'undefined' && ratingMap[game.id]) ? ratingMap[game.id] : null; %>
                <%= gr ? gr.avg : '-' %>
              </span>
            </div>
            <% if (game.categories && game.categories.length > 0 && catLabelMap) { %>
            <div class="mt-1.5 flex flex-wrap gap-1">
              <% game.categories.slice(0, 3).forEach(function(gc) { %>
              <span class="inline-flex rounded-full bg-brand-500/10 px-1.5 py-0.5 text-[10px] font-medium text-brand-400"><%= catLabelMap[gc.category_value] || gc.category_value %></span>
              <% }) %>
              <% if (game.categories.length > 3) { %>
              <span class="inline-flex rounded-full bg-gray-700 px-1.5 py-0.5 text-[10px] text-gray-400">+<%= game.categories.length - 3 %></span>
              <% } %>
            </div>
            <% } %>
          </div>
        </a>
        <% }) %>
      </div>

      <div id="list-view" class="hidden rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Game</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden sm:table-cell">Plataforma</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Arquivos</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Downloads</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider hidden md:table-cell">Avaliacao</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% games.forEach(game => { %>
            <tr class="hover:bg-gray-700/50 transition-colors">
              <td class="px-4 py-3">
                <a href="/games/<%= game.id %>" class="flex items-center gap-3 group">
                  <div class="h-10 w-10 rounded-lg bg-gray-700 overflow-hidden shrink-0">
                    <% if (game.cover_image) { %>
                    <img src="<%= game.cover_image %>" alt="" class="h-full w-full object-cover">
                    <% } else { %>
                    <div class="h-full w-full flex items-center justify-center">
                      <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 6.75v10.5A2.25 2.25 0 003.75 21z" /></svg>
                    </div>
                    <% } %>
                  </div>
                  <div>
                    <span class="text-sm font-medium text-white group-hover:text-brand-400 truncate block"><%= game.title %></span>
                    <% if (game.categories && game.categories.length > 0 && catLabelMap) { %>
                    <div class="flex flex-wrap gap-1 mt-0.5">
                      <% game.categories.slice(0, 3).forEach(function(gc) { %>
                      <span class="inline-flex rounded-full bg-brand-500/10 px-1.5 py-0.5 text-[10px] font-medium text-brand-400"><%= catLabelMap[gc.category_value] || gc.category_value %></span>
                      <% }) %>
                      <% if (game.categories.length > 3) { %>
                      <span class="inline-flex rounded-full bg-gray-700 px-1.5 py-0.5 text-[10px] text-gray-400">+<%= game.categories.length - 3 %></span>
                      <% } %>
                    </div>
                    <% } %>
                  </div>
                </a>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <span class="text-sm text-gray-300 capitalize"><%= game.platform.replace('_', ' ') %></span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-gray-400"><%= game.files ? game.files.length : 0 %></span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="inline-flex items-center gap-1 text-sm text-gray-400">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  <%= (typeof downloadCountMap !== 'undefined' && downloadCountMap[game.id]) ? downloadCountMap[game.id] : 0 %>
                </span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% var lr = (typeof ratingMap !== 'undefined' && ratingMap[game.id]) ? ratingMap[game.id] : null; %>
                <span class="inline-flex items-center gap-1 text-sm text-yellow-400">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <span class="text-gray-400"><%= lr ? lr.avg + ' (' + lr.votes + ')' : '-' %></span>
                </span>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= game.status === 'active' ? 'bg-green-500/20 text-green-400' : game.status === 'standby' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-gray-500/20 text-gray-400' %>">
                  <%= game.status === 'active' ? 'Ativo' : game.status === 'standby' ? 'Standby' : 'Inativo' %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/games/<%= game.id %>" class="rounded-lg p-1.5 text-gray-400 hover:text-white hover:bg-gray-600 transition-colors" title="Ver detalhes">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </a>
                  <a href="/games/<%= game.id %>/edit" class="rounded-lg p-1.5 text-gray-400 hover:text-brand-400 hover:bg-gray-600 transition-colors" title="Editar">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                  </a>
                  <button type="button" onclick="deleteGame(<%= game.id %>, '<%= game.title.replace(/'/g, "\\'") %>', event)" class="rounded-lg p-1.5 text-gray-400 hover:text-red-400 hover:bg-gray-600 transition-colors" title="Excluir">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                  </button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <nav class="mt-6 flex items-center justify-center gap-2">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/games?page=<%= i %>&search=<%= search %>&platform=<%= platform %>&limit=<%= limit %>"
          class="rounded-lg px-3 py-2 text-sm font-medium transition-colors <%= i === currentPage ? 'bg-brand-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white border border-gray-700' %>">
          <%= i %>
        </a>
        <% } %>
      </nav>
      <% } %>
      <% } %>

      <script>
      (function() {
        document.addEventListener('click', function(e) {
          var container = document.getElementById('csv-dropdown-container');
          if (container && !container.contains(e.target)) {
            var dd = document.getElementById('csv-dropdown');
            if (dd) dd.classList.add('hidden');
          }
        });
        try {
          var saved = localStorage.getItem('games_view_mode');
          if (saved === 'list' || saved === 'grid') setViewMode(saved);
        } catch(e) {}
      })();
      </script>

    </main>
  </div>
</body>
</html>
