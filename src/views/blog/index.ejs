<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Blog</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <script>
      function deletePost(postId, postTitle, event) {
        if (event) { event.preventDefault(); event.stopPropagation(); }
        if (confirm('Tem certeza que deseja excluir o post "' + postTitle + '"?\nEsta ação não pode ser desfeita.')) {
          var form = document.createElement('form');
          form.method = 'POST';
          form.action = '/blog/' + postId + '/delete';
          document.body.appendChild(form);
          form.submit();
        }
      }
      </script>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-white">Blog</h1>
          <p class="mt-1 text-sm text-gray-400"><%= totalPosts %> post(s) no total</p>
        </div>
        <a href="/blog/new" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Post
        </a>
      </div>

      <div class="mb-6 flex flex-col sm:flex-row gap-2">
        <form action="/blog" method="GET" class="flex flex-1 gap-2" id="filterForm">
          <input type="text" name="search" value="<%= search %>" placeholder="Buscar posts..."
            class="flex-1 rounded-lg bg-gray-800 border border-gray-700 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
          <select name="category_id" class="rounded-lg bg-gray-800 border border-gray-700 px-4 py-2.5 text-white text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent" onchange="document.getElementById('filterForm').submit()">
            <option value="">Todas categorias</option>
            <% if (typeof categories !== 'undefined' && categories) { %>
            <% categories.forEach(function(cat) { %>
            <option value="<%= cat.id %>" <%= selectedCategory == cat.id ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
            <% } %>
          </select>
          <select name="limit" class="rounded-lg bg-gray-800 border border-gray-700 px-3 py-2.5 text-white text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent" onchange="document.getElementById('filterForm').submit()">
            <option value="15" <%= perPage == 15 ? 'selected' : '' %>>15</option>
            <option value="30" <%= perPage == 30 ? 'selected' : '' %>>30</option>
            <option value="50" <%= perPage == 50 ? 'selected' : '' %>>50</option>
          </select>
          <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-600 transition-colors">Buscar</button>
          <% if (search || selectedCategory) { %>
          <a href="/blog" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Limpar</a>
          <% } %>
        </form>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-700">
          <thead class="bg-gray-800/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">T&iacute;tulo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Autor</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Categoria</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Data</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">A&ccedil;&otilde;es</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (posts.length === 0) { %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                <p class="text-lg mb-2">Nenhum post encontrado</p>
                <a href="/blog/new" class="text-brand-400 hover:text-brand-300">Criar primeiro post</a>
              </td>
            </tr>
            <% } %>
            <% posts.forEach(function(post) { %>
            <tr class="hover:bg-gray-700/50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if (post.cover_image_url) { %>
                  <img src="<%= post.cover_image_url %>" alt="" class="h-10 w-14 rounded object-cover flex-shrink-0">
                  <% } %>
                  <div>
                    <p class="text-sm font-medium text-white flex items-center gap-1.5">
                      <% if (post.pinned) { %>
                      <svg class="h-4 w-4 text-yellow-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg>
                      <% } %>
                      <%= post.title %>
                    </p>
                    <p class="text-xs text-gray-400 mt-0.5 line-clamp-1"><%= post.content ? post.content.replace(/<[^>]*>/g, '').substring(0, 100) : '' %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-300"><%= post.author ? post.author.username : 'N/A' %></td>
              <td class="px-6 py-4 text-sm text-gray-300"><%= post.category ? post.category.name : '-' %></td>
              <td class="px-6 py-4">
                <% if (post.published) { %>
                <span class="inline-flex items-center rounded-full bg-green-900/50 px-2.5 py-0.5 text-xs font-medium text-green-400 border border-green-500/30">Publicado</span>
                <% } else if (post.published_at && new Date(post.published_at) > new Date()) { %>
                <span class="inline-flex items-center rounded-full bg-blue-900/50 px-2.5 py-0.5 text-xs font-medium text-blue-400 border border-blue-500/30">Agendado</span>
                <% } else { %>
                <span class="inline-flex items-center rounded-full bg-yellow-900/50 px-2.5 py-0.5 text-xs font-medium text-yellow-400 border border-yellow-500/30">Rascunho</span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-300">
                <%= formatDateTime(post.published_at || post.createdAt) %>
                <% if (post.published_at && !post.published && new Date(post.published_at) > new Date()) { %>
                <br><span class="text-xs text-blue-400">Publica em: <%= formatDateTime(post.published_at) %></span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/blog/<%= post.id %>/edit" class="rounded-lg bg-gray-700 p-2 text-gray-300 hover:text-white hover:bg-gray-600 transition-colors" title="Editar">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                  </a>
                  <button onclick="deletePost(<%= post.id %>, '<%= post.title.replace(/'/g, "\\'") %>', event)" class="rounded-lg bg-gray-700 p-2 text-red-400 hover:text-red-300 hover:bg-red-900/30 transition-colors" title="Excluir">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                  </button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <div class="mt-6 flex items-center justify-between">
        <p class="text-sm text-gray-400">P&aacute;gina <%= currentPage %> de <%= totalPages %> (<%= totalPosts %> posts)</p>
        <div class="flex gap-2">
          <% if (currentPage > 1) { %>
          <a href="/blog?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category_id=' + selectedCategory : '' %><%= perPage != 15 ? '&limit=' + perPage : '' %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors">Anterior</a>
          <% } %>
          <% for (var p = 1; p <= totalPages; p++) { %>
            <% if (p === currentPage) { %>
            <span class="rounded-lg bg-brand-600 px-3 py-2 text-sm text-white"><%= p %></span>
            <% } else if (p === 1 || p === totalPages || (p >= currentPage - 2 && p <= currentPage + 2)) { %>
            <a href="/blog?page=<%= p %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category_id=' + selectedCategory : '' %><%= perPage != 15 ? '&limit=' + perPage : '' %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors"><%= p %></a>
            <% } else if (p === currentPage - 3 || p === currentPage + 3) { %>
            <span class="px-2 py-2 text-sm text-gray-500">...</span>
            <% } %>
          <% } %>
          <% if (currentPage < totalPages) { %>
          <a href="/blog?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= selectedCategory ? '&category_id=' + selectedCategory : '' %><%= perPage != 15 ? '&limit=' + perPage : '' %>" class="rounded-lg bg-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-600 transition-colors">Pr&oacute;xima</a>
          <% } %>
        </div>
      </div>
      <% } %>

    </main>
  </div>
</body>
</html>
