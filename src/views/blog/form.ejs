<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - <%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('../partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('../partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
      <style>
        .ql-toolbar.ql-snow { border-color: #374151 !important; background: #1f2937; border-radius: 0.5rem 0.5rem 0 0; }
        .ql-container.ql-snow { border-color: #374151 !important; background: #374151; border-radius: 0 0 0.5rem 0.5rem; min-height: 250px; }
        .ql-editor { color: #fff; font-size: 0.875rem; min-height: 250px; }
        .ql-editor.ql-blank::before { color: #9ca3af; font-style: normal; }
        .ql-snow .ql-stroke { stroke: #9ca3af; }
        .ql-snow .ql-fill { fill: #9ca3af; }
        .ql-snow .ql-picker-label { color: #9ca3af; }
        .ql-snow .ql-picker-options { background: #1f2937; border-color: #374151; }
        .ql-snow .ql-picker-item { color: #d1d5db; }
        .ql-snow .ql-picker-item:hover { color: #fff; }
        .ql-snow .ql-active .ql-stroke { stroke: #22c55e; }
        .ql-snow .ql-active .ql-fill { fill: #22c55e; }
        .ql-snow .ql-active { color: #22c55e; }
        .ql-snow a { color: #4ade80; }
        #htmlToggleBtn { transition: background-color 0.2s, color 0.2s; }
        #htmlToggleBtn.active { background: #22c55e; color: #fff; }
        #htmlTextarea { display: none; width: 100%; min-height: 250px; background: #1e1e2e; color: #e2e8f0; border: 1px solid #374151; border-radius: 0 0 0.5rem 0.5rem; padding: 12px; font-family: 'Courier New', monospace; font-size: 13px; resize: vertical; tab-size: 2; }
        .link-dialog-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; align-items: center; justify-content: center; }
        .link-dialog { background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 24px; width: 400px; max-width: 90vw; }
        .link-dialog h3 { color: #fff; font-size: 1rem; margin: 0 0 16px; }
        .link-dialog label { display: block; color: #d1d5db; font-size: 0.875rem; margin-bottom: 4px; }
        .link-dialog input[type="text"] { width: 100%; background: #374151; border: 1px solid #4b5563; border-radius: 0.5rem; padding: 8px 12px; color: #fff; font-size: 0.875rem; margin-bottom: 12px; box-sizing: border-box; }
        .link-dialog .checkbox-row { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
        .link-dialog .checkbox-row input[type="checkbox"] { width: 18px; height: 18px; accent-color: #22c55e; }
        .link-dialog .checkbox-row span { color: #d1d5db; font-size: 0.875rem; }
        .link-dialog .btn-row { display: flex; justify-content: flex-end; gap: 8px; }
        .link-dialog .btn-row button { padding: 8px 16px; border-radius: 0.5rem; font-size: 0.875rem; cursor: pointer; border: none; }
        .link-dialog .btn-cancel { background: #374151; color: #d1d5db; }
        .link-dialog .btn-cancel:hover { background: #4b5563; }
        .link-dialog .btn-confirm { background: #22c55e; color: #fff; }
        .link-dialog .btn-confirm:hover { background: #16a34a; }
      </style>

      <div class="mb-6">
        <a href="/blog" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Voltar
        </a>
      </div>

      <% if (error) { %>
      <div class="mb-6 rounded-lg bg-red-900/50 border border-red-500/50 p-4">
        <p class="text-sm text-red-300"><%= error %></p>
      </div>
      <% } %>

      <form id="blogForm" action="<%= post && post.id ? '/blog/' + post.id : '/blog' %>" method="POST" class="space-y-6">

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
          <h3 class="text-lg font-medium text-white mb-4"><%= post && post.id ? 'Editar Post' : 'Novo Post' %></h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">T&iacute;tulo</label>
              <input type="text" name="title" value="<%= post ? post.title : '' %>" required
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                placeholder="Título do post">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Conte&uacute;do</label>
              <input type="hidden" name="content" id="contentInput" value="">
              <div id="editor"></div>
              <textarea id="htmlTextarea" spellcheck="false"></textarea>
              <button type="button" id="htmlToggleBtn" class="mt-2 inline-flex items-center gap-1.5 rounded-lg bg-gray-700 border border-gray-600 px-3 py-1.5 text-xs font-medium text-gray-300 hover:bg-gray-600">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
                Ver HTML
              </button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">URL da Imagem de Capa (opcional)</label>
              <div class="flex gap-2">
                <input type="url" name="cover_image_url" id="coverImageUrl" value="<%= post ? (post.cover_image_url || '') : '' %>"
                  class="flex-1 rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm"
                  placeholder="https://exemplo.com/imagem.jpg">
                <label class="rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors cursor-pointer inline-flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
                  Upload
                  <input type="file" accept="image/*" class="hidden" onchange="uploadCoverImage(this)">
                </label>
              </div>
              <% if (post && post.cover_image_url) { %>
              <div class="mt-2" id="coverPreview">
                <img src="<%= post.cover_image_url %>" alt="Preview" class="h-32 rounded-lg object-cover">
              </div>
              <% } else { %>
              <div class="mt-2 hidden" id="coverPreview">
                <img src="" alt="Preview" class="h-32 rounded-lg object-cover">
              </div>
              <% } %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Categoria (opcional)</label>
              <select name="category_id"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
                <option value="">Sem categoria</option>
                <% if (typeof categories !== 'undefined' && categories) { %>
                <% categories.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= post && (post.category_id == cat.id) ? 'selected' : '' %>><%= cat.name %></option>
                <% }) %>
                <% } %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Agendar Publica&ccedil;&atilde;o (opcional)</label>
              <input type="datetime-local" name="published_at" id="publishedAt"
                value="<%= post && post.published_at ? new Date(new Date(post.published_at).getTime() - new Date(post.published_at).getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>"
                class="w-full rounded-lg bg-gray-700 border border-gray-600 px-4 py-2.5 text-white focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
              <p class="mt-1 text-xs text-gray-500">Deixe vazio para publica&ccedil;&atilde;o imediata ao marcar como publicado. Se definir uma data futura, o post ser&aacute; publicado automaticamente nessa data.</p>
            </div>
            <div class="flex gap-6">
              <div>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="hidden" name="published" value="0">
                  <input type="checkbox" name="published" value="1" <%= post && post.published ? 'checked' : '' %>
                    class="h-5 w-5 rounded border-gray-600 bg-gray-700 text-brand-500 focus:ring-brand-500">
                  <span class="text-sm font-medium text-gray-300">Publicado</span>
                </label>
                <p class="mt-1 text-xs text-gray-500">Marque para tornar o post vis&iacute;vel na WebUI</p>
              </div>
              <div>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="hidden" name="pinned" value="0">
                  <input type="checkbox" name="pinned" value="1" <%= post && post.pinned ? 'checked' : '' %>
                    class="h-5 w-5 rounded border-gray-600 bg-gray-700 text-yellow-500 focus:ring-yellow-500">
                  <span class="text-sm font-medium text-gray-300">Fixar Post</span>
                </label>
                <p class="mt-1 text-xs text-gray-500">Posts fixados aparecem sempre no topo</p>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-end gap-3">
          <a href="/blog" class="rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors">Cancelar</a>
          <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-brand-700 transition-colors">
            <%= post && post.id ? 'Salvar' : 'Criar Post' %>
          </button>
        </div>

      </form>

      <% if (post && post.id) { %>
      <div class="rounded-xl bg-gray-800 border border-gray-700 p-6">
        <h3 class="text-lg font-medium text-white mb-4">Comentários</h3>
        <div id="blog-comments-admin">
          <p class="text-sm text-gray-400">Carregando comentários...</p>
        </div>
      </div>
      <% } %>

      <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
      <script>
        (function() {
          function initQuillEditor() {
            if (typeof Quill === 'undefined') {
              setTimeout(initQuillEditor, 100);
              return;
            }
            var editorEl = document.getElementById('editor');
            if (!editorEl) return;
            if (editorEl.classList.contains('ql-container')) return;

            var Inline = Quill.import('blots/inline');
            var CustomLink = (function(_super) {
              function CL() { return _super.apply(this, arguments) || this; }
              CL.prototype = Object.create(_super.prototype);
              CL.prototype.constructor = CL;
              CL.create = function(value) {
                var node = _super.create.call(this);
                var href = typeof value === 'object' ? (value.href || '') : (value || '');
                href = CL.sanitize(href);
                node.setAttribute('href', href);
                if (typeof value === 'object' && value.target) {
                  node.setAttribute('target', value.target);
                  node.setAttribute('rel', 'noopener noreferrer');
                }
                return node;
              };
              CL.formats = function(node) {
                var href = node.getAttribute('href');
                var target = node.getAttribute('target');
                if (target) {
                  return { href: href, target: target };
                }
                return href;
              };
              CL.sanitize = function(url) {
                if (typeof url === 'object') url = url.href || '';
                var anchor = document.createElement('a');
                anchor.href = url;
                var protocol = anchor.href.slice(0, anchor.href.indexOf(':'));
                if (['http', 'https', 'mailto', 'tel'].indexOf(protocol) > -1) return url;
                return 'about:blank';
              };
              return CL;
            })(Inline);
            CustomLink.blotName = 'link';
            CustomLink.tagName = 'A';
            CustomLink.SANITIZED_URL = 'about:blank';
            Quill.register(CustomLink, true);

            function showLinkDialog(quill) {
              var range = quill.getSelection(true);
              if (!range) return;
              var existingFormat = quill.getFormat(range);
              var existingUrl = '';
              var existingNewTab = false;
              if (existingFormat.link) {
                if (typeof existingFormat.link === 'object') {
                  existingUrl = existingFormat.link.href || '';
                  existingNewTab = existingFormat.link.target === '_blank';
                } else {
                  existingUrl = existingFormat.link;
                }
              }

              var overlay = document.createElement('div');
              overlay.className = 'link-dialog-overlay';
              overlay.innerHTML = '<div class="link-dialog">' +
                '<h3>Inserir Link</h3>' +
                '<label>URL</label>' +
                '<input type="text" id="linkDialogUrl" value="' + existingUrl.replace(/"/g, '&quot;') + '" placeholder="https://">' +
                '<div class="checkbox-row"><input type="checkbox" id="linkDialogNewTab"' + (existingNewTab ? ' checked' : '') + '><span>Abrir em nova aba</span></div>' +
                '<div class="btn-row"><button type="button" class="btn-cancel" id="linkDialogCancel">Cancelar</button>' +
                '<button type="button" class="btn-confirm" id="linkDialogConfirm">Aplicar</button></div></div>';
              document.body.appendChild(overlay);

              var urlInput = document.getElementById('linkDialogUrl');
              urlInput.focus();
              urlInput.select();

              function closeDialog() { if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }

              document.getElementById('linkDialogCancel').onclick = function() {
                closeDialog();
                if (existingFormat.link) {
                  quill.format('link', false);
                }
              };

              document.getElementById('linkDialogConfirm').onclick = function() {
                var url = urlInput.value.trim();
                var newTab = document.getElementById('linkDialogNewTab').checked;
                closeDialog();
                if (!url) {
                  quill.format('link', false);
                  return;
                }
                if (newTab) {
                  quill.format('link', { href: url, target: '_blank' });
                } else {
                  quill.format('link', url);
                }
              };

              overlay.addEventListener('click', function(e) {
                if (e.target === overlay) closeDialog();
              });

              urlInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); document.getElementById('linkDialogConfirm').click(); }
                if (e.key === 'Escape') { closeDialog(); }
              });
            }

            var quill = new Quill('#editor', {
              theme: 'snow',
              placeholder: 'Escreva o conteúdo do post...',
              modules: {
                toolbar: {
                  container: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['blockquote', 'code-block'],
                    ['link', 'image', 'video'],
                    [{ 'align': [] }],
                    ['clean']
                  ],
                  handlers: {
                    link: function() { showLinkDialog(quill); },
                    image: function() {
                      var input = document.createElement('input');
                      input.setAttribute('type', 'file');
                      input.setAttribute('accept', 'image/*');
                      input.click();
                      input.onchange = function() {
                        var file = input.files[0];
                        if (!file) return;
                        var formData = new FormData();
                        formData.append('image', file);
                        fetch('/blog/upload', { method: 'POST', body: formData })
                          .then(function(r) { return r.json(); })
                          .then(function(data) {
                            if (data.success && data.url) {
                              var range = quill.getSelection(true);
                              quill.insertEmbed(range.index, 'image', data.url);
                            } else {
                              alert('Erro ao enviar imagem: ' + (data.error || 'Erro desconhecido'));
                            }
                          })
                          .catch(function(err) { alert('Erro ao enviar imagem: ' + err.message); });
                      };
                    }
                  }
                }
              }
            });

            <% if (post && post.content) { %>
            quill.root.innerHTML = <%- JSON.stringify(post.content) %>;
            <% } %>

            var htmlMode = false;
            var htmlTextarea = document.getElementById('htmlTextarea');
            var toggleBtn = document.getElementById('htmlToggleBtn');
            var qlToolbar = document.querySelector('.ql-toolbar');
            var qlContainer = document.querySelector('.ql-container');

            toggleBtn.addEventListener('click', function() {
              htmlMode = !htmlMode;
              if (htmlMode) {
                htmlTextarea.value = quill.root.innerHTML;
                qlToolbar.style.display = 'none';
                qlContainer.style.display = 'none';
                htmlTextarea.style.display = 'block';
                toggleBtn.classList.add('active');
                toggleBtn.querySelector('svg').nextSibling.textContent = ' Editor Visual';
              } else {
                quill.root.innerHTML = htmlTextarea.value;
                qlToolbar.style.display = '';
                qlContainer.style.display = '';
                htmlTextarea.style.display = 'none';
                toggleBtn.classList.remove('active');
                toggleBtn.querySelector('svg').nextSibling.textContent = ' Ver HTML';
              }
            });

            document.getElementById('blogForm').addEventListener('submit', function(e) {
              var content;
              if (htmlMode) {
                content = htmlTextarea.value;
                quill.root.innerHTML = content;
              } else {
                content = quill.root.innerHTML;
              }
              if (content === '<p><br></p>' || content.trim() === '') {
                e.preventDefault();
                alert('O conteúdo do post é obrigatório.');
                return;
              }
              document.getElementById('contentInput').value = content;
            });

            window.uploadCoverImage = function(input) {
              var file = input.files[0];
              if (!file) return;
              var formData = new FormData();
              formData.append('image', file);
              fetch('/blog/upload', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.success && data.url) {
                    document.getElementById('coverImageUrl').value = data.url;
                    var preview = document.getElementById('coverPreview');
                    preview.classList.remove('hidden');
                    preview.querySelector('img').src = data.url;
                  } else {
                    alert('Erro ao enviar imagem: ' + (data.error || 'Erro desconhecido'));
                  }
                })
                .catch(function(err) { alert('Erro ao enviar imagem: ' + err.message); });
            };
          }
          initQuillEditor();
        })();
      </script>

      <% if (post && post.id) { %>
      <script>
        (function() {
          var postId = <%= post.id %>;
          var container = document.getElementById('blog-comments-admin');
          if (!container) return;

          function loadComments() {
            fetch('/api/blog/posts/' + postId + '/comments?limit=50')
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (!data.success) {
                  container.innerHTML = '<p class="text-sm text-red-400">Erro ao carregar comentários.</p>';
                  return;
                }
                var comments = data.comments || [];
                if (comments.length === 0) {
                  container.innerHTML = '<p class="text-sm text-gray-500">Nenhum comentário neste post.</p>';
                  return;
                }
                function esc(s) { var d = document.createElement('div'); d.appendChild(document.createTextNode(s)); return d.innerHTML; }
                var html = '<div class="space-y-3">';
                comments.forEach(function(c) {
                  var up = c.userProfile || {};
                  var name = up.display_name || up.username || 'Anônimo';
                  var dateStr = '';
                  if (c.created_at || c.createdAt) {
                    try { dateStr = new Date(c.created_at || c.createdAt).toLocaleString('pt-BR'); } catch(e) {}
                  }
                  html += '<div class="flex items-start gap-3 p-3 rounded-lg bg-gray-700/50" id="admin-comment-' + c.id + '">' +
                    '<div class="flex-1 min-w-0">' +
                      '<div class="flex items-center gap-2">' +
                        '<span class="text-sm font-medium text-white">' + esc(name) + '</span>' +
                        '<span class="text-xs text-gray-500">' + esc(dateStr) + '</span>' +
                      '</div>' +
                      '<p class="text-sm text-gray-300 mt-1 whitespace-pre-wrap">' + esc(c.comment_text || '') + '</p>' +
                    '</div>' +
                    '<button onclick="deleteAdminComment(' + c.id + ')" class="flex-shrink-0 p-1.5 rounded-lg bg-red-900/50 text-red-400 hover:bg-red-900 hover:text-red-300 transition-colors" title="Excluir">' +
                      '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>' +
                    '</button>' +
                  '</div>';
                });
                html += '</div>';
                html += '<p class="text-xs text-gray-500 mt-3">' + data.total + ' comentário(s)</p>';
                container.innerHTML = html;
              })
              .catch(function() {
                container.innerHTML = '<p class="text-sm text-red-400">Erro ao carregar comentários.</p>';
              });
          }

          window.deleteAdminComment = function(commentId) {
            if (!confirm('Excluir este comentário?')) return;
            var el = document.getElementById('admin-comment-' + commentId);
            if (el) el.style.opacity = '0.5';
            fetch('/blog/' + postId + '/comments/' + commentId, { method: 'DELETE' })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                if (data.success) {
                  loadComments();
                } else {
                  if (el) el.style.opacity = '1';
                  alert('Erro: ' + (data.error || 'Falha ao excluir'));
                }
              })
              .catch(function() {
                if (el) el.style.opacity = '1';
                alert('Erro ao excluir comentário');
              });
          };

          loadComments();
        })();
      </script>
      <% } %>

    </main>
  </div>
</body>
</html>
