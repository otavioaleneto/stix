<!DOCTYPE html>
<html lang="pt-BR" class="h-full bg-gray-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GODSend - Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{brand:{50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d'}}}}}</script>
</head>
<body class="h-full">
  <%- include('partials/sidebar') %>
  <div class="lg:pl-64 min-h-full sidebar-content-area">
    <%- include('partials/navbar') %>
    <main class="p-4 sm:p-6 lg:p-8">

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-orange-500/10 p-3">
              <svg class="h-6 w-6 text-orange-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Downloads Hoje</p>
              <p class="text-2xl font-bold text-white"><%= downloadsToday %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-blue-500/10 p-3">
              <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Total de Posts</p>
              <p class="text-2xl font-bold text-white"><%= totalPosts %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-purple-500/10 p-3">
              <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Total de Coment&aacute;rios</p>
              <p class="text-2xl font-bold text-white"><%= totalComments %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-green-500/10 p-3">
              <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Salas Ativas</p>
              <p class="text-2xl font-bold text-white"><%= activeRoomsCount %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-8">
        <a href="/blog/new" class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Post
        </a>
        <a href="/events/new" class="inline-flex items-center gap-2 rounded-lg bg-purple-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-purple-700 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Evento
        </a>
        <a href="/games/new" class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-green-700 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          Novo Game
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="rounded-xl bg-gray-800 border border-gray-700">
          <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
            <h3 class="text-sm font-medium text-white">Posts Recentes</h3>
            <a href="/blog" class="text-sm text-brand-400 hover:text-brand-300">Ver Todos</a>
          </div>
          <div class="divide-y divide-gray-700">
            <% if (recentPosts.length === 0) { %>
            <div class="px-5 py-6 text-center text-gray-400 text-sm">Nenhum post ainda.</div>
            <% } %>
            <% recentPosts.forEach(post => { %>
            <div class="px-5 py-3">
              <p class="text-sm font-medium text-white truncate"><%= post.title %></p>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-xs text-gray-400"><%= post.author ? post.author.username : 'Admin' %></span>
                <% if (post.category) { %>
                <span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-0.5 rounded-full"><%= post.category.name %></span>
                <% } %>
                <span class="text-xs text-gray-500 ml-auto"><%= new Date(post.created_at || post.createdAt).toLocaleDateString('pt-BR') %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <div class="rounded-xl bg-gray-800 border border-gray-700">
          <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
            <h3 class="text-sm font-medium text-white">Coment&aacute;rios Recentes</h3>
            <a href="/social/comments" class="text-sm text-brand-400 hover:text-brand-300">Ver Todos</a>
          </div>
          <div class="divide-y divide-gray-700">
            <% if (recentComments.length === 0) { %>
            <div class="px-5 py-6 text-center text-gray-400 text-sm">Nenhum coment&aacute;rio ainda.</div>
            <% } %>
            <% recentComments.forEach(comment => { %>
            <div class="px-5 py-3">
              <p class="text-sm text-white truncate"><%= comment.comment_text %></p>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-xs text-brand-400"><%= comment.userProfile ? comment.userProfile.display_name : 'Usu&aacute;rio' %></span>
                <span class="text-xs text-gray-500">&middot;</span>
                <span class="text-xs text-gray-400"><%= comment.game ? comment.game.title : '' %></span>
                <span class="text-xs text-gray-500 ml-auto"><%= new Date(comment.createdAt).toLocaleDateString('pt-BR') %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="rounded-xl bg-gray-800 border border-gray-700">
          <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
            <h3 class="text-sm font-medium text-white">Salas Recentes</h3>
            <a href="/social/rooms" class="text-sm text-brand-400 hover:text-brand-300">Ver Todos</a>
          </div>
          <div class="divide-y divide-gray-700">
            <% if (recentRooms.length === 0) { %>
            <div class="px-5 py-6 text-center text-gray-400 text-sm">Nenhuma sala criada ainda.</div>
            <% } %>
            <% recentRooms.forEach(room => { %>
            <div class="px-5 py-3">
              <div class="flex items-center gap-2">
                <p class="text-sm font-medium text-white truncate flex-1"><%= room.title %></p>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= room.status === 'active' ? 'bg-green-500/10 text-green-400' : room.status === 'scheduled' ? 'bg-yellow-500/10 text-yellow-400' : 'bg-gray-500/10 text-gray-400' %>">
                  <%= room.status === 'active' ? 'Ativa' : room.status === 'scheduled' ? 'Agendada' : room.status === 'finished' ? 'Finalizada' : 'Cancelada' %>
                </span>
              </div>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-xs text-brand-400"><%= room.creator ? room.creator.display_name : '' %></span>
                <span class="text-xs text-gray-500">&middot;</span>
                <span class="text-xs text-gray-400"><%= room.game ? room.game.title : (room.game_title || '') %></span>
                <span class="text-xs text-gray-500 ml-auto"><%= room.max_players %> jogadores</span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <div class="rounded-xl bg-gray-800 border border-gray-700">
          <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
            <h3 class="text-sm font-medium text-white">Reports</h3>
            <a href="/reports" class="text-sm text-brand-400 hover:text-brand-300">Ver Todos</a>
          </div>
          <div class="divide-y divide-gray-700">
            <% if (recentReports.length === 0) { %>
            <div class="px-5 py-6 text-center text-gray-400 text-sm">Nenhum report ainda.</div>
            <% } %>
            <% recentReports.forEach(report => { %>
            <div class="px-5 py-3">
              <div class="flex items-center gap-2">
                <p class="text-sm font-medium text-white truncate flex-1"><%= report.game_title || 'Arquivo #' + report.game_file_id %></p>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-500/10 text-red-400"><%= report.report_type %></span>
              </div>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-xs text-gray-400"><%= report.file_name || '' %></span>
                <span class="text-xs text-gray-500 ml-auto"><%= new Date(report.createdAt).toLocaleDateString('pt-BR') %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="rounded-xl bg-gray-800 border border-gray-700 p-5">
          <h3 class="text-sm font-medium text-gray-400 mb-4">Estat&iacute;sticas de Downloads</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Hoje</span>
              <span class="text-sm font-medium bg-orange-500/20 text-orange-300 px-2.5 py-0.5 rounded-full"><%= downloadsToday %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Esta Semana</span>
              <span class="text-sm font-medium bg-blue-500/20 text-blue-300 px-2.5 py-0.5 rounded-full"><%= downloadsWeek %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Este M&ecirc;s</span>
              <span class="text-sm font-medium bg-purple-500/20 text-purple-300 px-2.5 py-0.5 rounded-full"><%= downloadsMonth %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Este Ano</span>
              <span class="text-sm font-medium bg-green-500/20 text-green-300 px-2.5 py-0.5 rounded-full"><%= downloadsYear %></span>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-gray-800 border border-gray-700 p-5">
          <h3 class="text-sm font-medium text-gray-400 mb-3">Por Plataforma</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Xbox 360</span>
              <span class="text-sm font-medium bg-blue-500/20 text-blue-300 px-2.5 py-0.5 rounded-full"><%= platformStats.xbox360 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Xbox Original</span>
              <span class="text-sm font-medium bg-green-500/20 text-green-300 px-2.5 py-0.5 rounded-full"><%= platformStats.xbox_original %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-300">Digital/XBLA</span>
              <span class="text-sm font-medium bg-purple-500/20 text-purple-300 px-2.5 py-0.5 rounded-full"><%= platformStats.digital %></span>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="rounded-xl bg-gray-800 border border-gray-700 p-5">
            <h3 class="text-sm font-medium text-gray-400 mb-3">WebDAV</h3>
            <div class="flex items-center gap-2">
              <% if (webdavStatus === 'connected') { %>
                <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
                <span class="text-sm text-green-300">Conectado</span>
              <% } else if (webdavStatus === 'disconnected') { %>
                <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <span class="text-sm text-red-300">Desconectado</span>
              <% } else { %>
                <span class="h-2.5 w-2.5 rounded-full bg-gray-400"></span>
                <span class="text-sm text-gray-300">N&atilde;o configurado</span>
              <% } %>
            </div>
            <a href="/settings" class="mt-3 inline-block text-sm text-brand-400 hover:text-brand-300">Configurar</a>
          </div>

          <div class="rounded-xl bg-gray-800 border border-gray-700 p-5">
            <h3 class="text-sm font-medium text-gray-400 mb-3">WordPress</h3>
            <div class="flex items-center gap-2">
              <% if (wpStatus === 'connected') { %>
                <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
                <span class="text-sm text-green-300">Conectado</span>
              <% } else if (wpStatus === 'error') { %>
                <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <span class="text-sm text-red-300">Erro de conex&atilde;o</span>
              <% } else { %>
                <span class="h-2.5 w-2.5 rounded-full bg-gray-400"></span>
                <span class="text-sm text-gray-300">N&atilde;o configurado</span>
              <% } %>
            </div>
            <a href="/settings" class="mt-3 inline-block text-sm text-brand-400 hover:text-brand-300">Configurar</a>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-blue-500/10 p-3">
              <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Total de Games</p>
              <p class="text-2xl font-bold text-white"><%= totalGames %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-green-500/10 p-3">
              <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Games Ativos</p>
              <p class="text-2xl font-bold text-white"><%= activeGames %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-purple-500/10 p-3">
              <svg class="h-6 w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Usu&aacute;rios Ativos</p>
              <p class="text-2xl font-bold text-white"><%= activeMembers %></p>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl bg-gray-800 border border-gray-700 p-5">
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-yellow-500/10 p-3">
              <svg class="h-6 w-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Arquivos</p>
              <p class="text-2xl font-bold text-white"><%= totalFiles %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-xl bg-gray-800 border border-gray-700">
        <div class="px-5 py-4 border-b border-gray-700 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <h3 class="text-sm font-medium text-white">Games Recentes</h3>
            <span class="text-xs text-gray-400">(<%= recentTotal %> total)</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-400">Por p&aacute;gina:</span>
            <% [15, 30, 50].forEach(function(val) { %>
            <a href="/dashboard?limit=<%= val %>&page=1"
              class="rounded-lg px-2.5 py-1 text-xs font-medium transition-colors <%= val === recentLimit ? 'bg-brand-600 text-white' : 'bg-gray-700 text-gray-400 hover:text-white' %>">
              <%= val %>
            </a>
            <% }) %>
            <a href="/games" class="text-sm text-brand-400 hover:text-brand-300 ml-2">Ver todos</a>
          </div>
        </div>
        <div class="divide-y divide-gray-700">
          <% if (recentGames.length === 0) { %>
          <div class="px-5 py-8 text-center text-gray-400 text-sm">Nenhum game cadastrado ainda.</div>
          <% } %>
          <% recentGames.forEach(game => { %>
          <div class="px-5 py-3 flex items-center gap-4">
            <% if (game.cover_image) { %>
            <img src="<%= game.cover_image %>" alt="" class="h-10 w-10 rounded-lg object-cover">
            <% } else { %>
            <div class="h-10 w-10 rounded-lg bg-gray-700 flex items-center justify-center">
              <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 6.75v10.5A2.25 2.25 0 003.75 21z" /></svg>
            </div>
            <% } %>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate"><%= game.title %></p>
              <p class="text-xs text-gray-400"><%= game.platform %> &middot; <%= game.files ? game.files.length : 0 %> arquivos</p>
            </div>
            <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium <%= game.status === 'active' ? 'bg-green-500/10 text-green-400' : 'bg-gray-500/10 text-gray-400' %>">
              <%= game.status === 'active' ? 'Ativo' : 'Inativo' %>
            </span>
          </div>
          <% }) %>
        </div>
        <% if (recentTotalPages > 1) { %>
        <div class="px-5 py-3 border-t border-gray-700 flex items-center justify-center gap-2">
          <% for (let i = 1; i <= recentTotalPages; i++) { %>
          <a href="/dashboard?page=<%= i %>&limit=<%= recentLimit %>"
            class="rounded-lg px-3 py-1.5 text-sm font-medium transition-colors <%= i === recentPage ? 'bg-brand-600 text-white' : 'bg-gray-700 text-gray-400 hover:text-white' %>">
            <%= i %>
          </a>
          <% } %>
        </div>
        <% } %>
      </div>

    </main>
  </div>
</body>
</html>
